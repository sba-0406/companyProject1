Shaik Bisma Alisha

//throttling

function throttle(fn,delay){

    let lastCall=0;

    return function(...args){

        let now=Date.now();

        let interval=now-lastCall;

        if(delay<interval){

            

            lastCall=now;

            return fn.apply(this,args);

        }

    }

}

 

function throttle2(fn,delay){

    let flag=true;

    return function(...args){

        if(flag){

            fn.apply(this,args);

            flag=false;

            setTimeout(()=>flag=true,delay);

        }

    }

}

 

timestamps. Filter
