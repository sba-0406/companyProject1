Build a Darwinbox API tool using the struct... by Shaik Bisma Alisha
4/10 4:15 PM
Shaik Bisma Alisha

Build a Darwinbox API tool using the structure below.

Follow the format exactly.

Return:

name (camelCase, no underscores)
description
signature
fetcher
transformer
sample input
sample output
Use:

reqOptions.host
reqOptions.cookie
reqOptions.pbqBeYWPUn
POST unless curl says otherwise
success when status === 1
error when status === 0
REFERENCE IMPLEMENTATION FORMAT
Name:
exampleToolName

Description:
Short description of action

Signature:
{
"type": "object",
"properties": {
"request_id": {
"type": "string",
"description": "Request ID"
},
"task_id": {
"type": "string",
"description": "Task ID"
},
"journey_action": {
"type": "string",
"default": "1"
}
},
"required": ["request_id", "task_id"]
}

Fetcher:
(function (args, reqOptions) {
return {
url: https://${reqOptions.host}/REPLACE_ENDPOINT,
method: "POST",
headers: {
"x-requested-with": "XMLHttpRequest",
"cookie": reqOptions.cookie
},
body: JSON.stringify({
journey_action: args.journey_action || "1",
request_id: args.request_id,
task_id: args.task_id,
pbqBeYWPUn: reqOptions.pbqBeYWPUn
})
};
})

Transformer:
(function (data, args, reqOptions) {
try {
const res = typeof data === "string" ? JSON.parse(data) : data;

if (res.status === 1) {
  return {
    status: "success",
    message: res.message || "Request successful"
  };
}

if (res.status === 0) {
  return {
    status: "error",
    message: res.message || res.error || "Request failed"
  };
}

return {
  status: "success",
  message: res.message || "Request completed"
};
} catch (e) {
return {
status: "error",
message: e.message || "Unable to parse response"
};
}
})

Sample Input:
{
"request_id": "abc123",
"task_id": "task456"
}

Sample Output:
{
"status": "success",
"message": "Request successful"
}

