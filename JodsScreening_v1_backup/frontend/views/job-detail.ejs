            async function saveAllSkillSelections() {
                const skills = Object.keys(targetCounts);
                if (skills.length === 0) return alert('No skills found.');

                showLoading('Saving all question selections...');
                let errors = [];
                for (const skill of skills) {
                    const checked = Array.from(
                        document.querySelectorAll(`.skill-checkbox[data-skill="${CSS.escape(skill)}"]:checked`)
                    ).map(cb => cb.value);

                    try {
                        const resp = await fetch(`/api/jobs/${jobId}/pool/save-selection`, {
                            method: 'PUT',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ skill, selectedIds: checked })
                        });
                        const result = await resp.json();
                        if (!result.success) errors.push(skill);
                    } catch (e) {
                        errors.push(skill);
                    }
                }
                hideLoading();
                if (errors.length > 0) {
                    alert(`Saved with errors for: ${errors.join(', ')}`);
                } else {
                    location.href = window.location.pathname + '?tab=tab-assessment&expand=pool&toast=✅ All questions saved!';
                }
            }

            async function regenerateScenarios() {
                if (!confirm('Regenerate all scenario templates?')) return;
                showLoading('AI is crafting behavioral scenarios...');
                try {
                    const response = await fetch(`/api/jobs/${jobId}/regenerate-scenarios`, {
                        method: 'POST'
                    });

                    const result = await response.json();
                    if (result.success) {
                        // For scenarios, we might need a separate renderer or just reload for now 
                        // but let's try to keep it AJAX if possible.
                        // For simplicity in this step, I'll reload scenarios but preserve tab
                        location.href = window.location.pathname + '?tab=tab-assessment&expand=pool&toast=Scenarios regenerated!';
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error regenerating scenarios');
                } finally {
                    hideLoading();
                }
            }

