                                <% if (job.status.trim()===' draft' && job.assessmentId) { %>
                                    <button onclick="publishJob()" class="btn">Publish Job</button>
                                    <% } %>
                                        <% if (job.status.trim()==='active' ) { %>
                                            <button onclick="closeJob()" class="btn btn-secondary">Close
                                                Job</button>
                                            <% } %>
                            </div>
            </div>
        </div>

        <script>
            const jobId = '<%= job._id %>';
            const targetCounts = <%- JSON.stringify(typeof skillCounts !== 'undefined' ? skillCounts : {}) %>;

            // Weight sliders
            const techWeight = document.getElementById('tech-weight');
            const softWeight = document.getElementById('soft-weight');
            const techValue = document.getElementById('tech-weight-value');
            const softValue = document.getElementById('soft-weight-value');

            if (techWeight && softWeight) {
                techWeight.addEventListener('input', (e) => {
                    const val = parseInt(e.target.value);
                    techValue.textContent = val + '%';
                    softWeight.value = 100 - val;
                    softValue.textContent = (100 - val) + '%';
                });

                softWeight.addEventListener('input', (e) => {
                    const val = parseInt(e.target.value);
                    softValue.textContent = val + '%';
                    techWeight.value = 100 - val;
                    techValue.textContent = (100 - val) + '%';
                });
            }

            async function saveAssessmentConfig() {
                const techWeight = parseInt(document.getElementById('tech-weight').value) / 100;
                const softWeight = parseInt(document.getElementById('soft-weight').value) / 100;
                const minTechScore = parseInt(document.getElementById('min-tech-score').value);
                const minSoftScore = parseInt(document.getElementById('min-soft-score').value);
                const questionsPerSkill = parseInt(document.getElementById('questions-per-skill').value);
                const allowAIGen = document.getElementById('allow-ai-gen').checked;

                const presetStrategy = 'balanced'; // Defaulted after UI removal

                // Harvest granular skill counts
                const skillConfigs = {};
                document.querySelectorAll('.skill-count-input').forEach(input => {
                    skillConfigs[input.dataset.skill] = parseInt(input.value);
                });

                try {
                    const response = await fetch(`/api/jobs/${jobId}/assessment`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            technicalWeight: techWeight,
                            softSkillWeight: softWeight,
                            minTechnicalScore: minTechScore,
                            minSoftSkillScore: minSoftScore,
                            questionsPerSkill: questionsPerSkill,
                            allowAIGeneration: allowAIGen,
                            presetStrategy: presetStrategy,
                            skillConfigs: skillConfigs,
                            screeningQuestions: Array.from(document.querySelectorAll('.screening-q-item')).map(item => ({
                                question: item.querySelector('.sq-text').value.trim(),
                                type: item.querySelector('.sq-type').value,
                                isKnockout: item.querySelector('.sq-knockout').checked,
                                expectedAnswer: item.querySelector('.sq-knockout').checked ? item.querySelector('.sq-expected').value : null
                            })).filter(q => q.question !== ''),
                            notificationSettings: {
                                sendInApp: document.getElementById('send-in-app').checked,
                                sendEmail: document.getElementById('send-email').checked
                            }
                        })
                    });

                    const result = await response.json();
                    if (result.success) {
                        alert('Assessment configuration saved!');
                        document.getElementById('strategy-hint').style.display = 'block';
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error saving configuration');
                }
            }

            /* 
           // REDUNDANT: These functions were used in the older individual-moderation UI.
           // The new UI uses the unified "Save Selection" model.
           
           async function moderateQuestion(questionId, action) {
               try {
                   const response = await fetch(`/api/jobs/${jobId}/questions/${questionId}`, {
                       method: 'PUT',
                       headers: { 'Content-Type': 'application/json' },
                       body: JSON.stringify({ action: action })
                   });

                   const result = await response.json();
                   if (result.success) {
                       renderTechnicalAssessment(result.data);
                       showToast(`Question ${action}d successfully`);
                   } else {
                       alert('Error: ' + result.error);
                   }
               } catch (error) {
                   alert('Error moderating question');
               }
           }

           async function removeQuestion(questionId) {
               if (!confirm('Remove this question from the assessment? (It stays in the question bank)')) return;
               try {
                   const response = await fetch(`/api/jobs/${jobId}/questions/${questionId}/remove`, {
                       method: 'DELETE'
                   });
                   const result = await response.json();
                   if (result.success) {
                       renderTechnicalAssessment(result.data);
                       showToast('Question removed from the pool');
                   }
                   else alert('Error: ' + result.error);
               } catch (e) {
                   alert('Error removing question');
               }
           }

           async function regenerateQuestions() {
               if (!confirm('This will update your technical questions based on the latest configuration. Continue?')) return;
               showLoading('AI is generating new technical questions...');
               try {
                   const response = await fetch(`/api/jobs/${jobId}/regenerate-questions`, {
                       method: 'POST'
                   });
                   const result = await response.json();
                   if (result.success) {
                       renderTechnicalAssessment(result.data);
                       showToast('Questions updated successfully!');
                   } else {
                       alert('Error: ' + result.error);
                   }
               } catch (error) {
                   alert('Error regenerating questions');
               } finally {
                   hideLoading();
               }
           }
           */
            function toggleSkillAccordion(skill) {
                const el = document.getElementById(`skill-content-${skill}`);
                const icon = document.getElementById(`accordion-icon-${skill}`);
                if (!el) return;
                const isHidden = el.style.display === 'none';
                el.style.display = isHidden ? 'block' : 'none';
                if (icon) {
                    icon.style.transform = isHidden ? 'rotate(90deg)' : 'rotate(0deg)';
                }
            }

            async function saveSelectionForSkill(skill) {
                // Use data attributes to avoid escaping issues with periods in skill names like Node.js
                const checkboxes = document.querySelectorAll(`.skill-checkbox[data-skill="${skill}"]:checked`);
                const selectedIds = Array.from(checkboxes).map(cb => cb.value);
                const targetCount = targetCounts[skill];

                if (selectedIds.length !== targetCount) {
                    alert(`Target is ${targetCount} questions! You have selected ${selectedIds.length}. Please select exactly ${targetCount} questions before saving.`);
                    return;
                }

                showLoading(`Saving selection for ${skill}...`);
                try {
                    const response = await fetch(`/api/jobs/${jobId}/pool/save-selection`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ skill, selectedIds })
                    });
                    const result = await response.json();
                    if (result.success) {
                        renderTechnicalAssessment(result.data);
                        showToast(`${skill} questions saved!`);
                        const el = document.getElementById(`skill-content-${skill}`);
                        const icon = document.getElementById(`accordion-icon-${skill}`);
                        if (el) el.style.display = 'none';
                        if (icon) icon.style.transform = 'rotate(0deg)';
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error saving selection: ' + error.message);
                } finally {
                    hideLoading();
                }
            }

            function enforceLimits(skill, targetCount) {
                // Use data attributes to prevent errors on strings with periods like Node.js
                const checkboxes = document.querySelectorAll(`.skill-checkbox[data-skill="${skill}"]`);
                const selectedCount = document.querySelectorAll(`.skill-checkbox[data-skill="${skill}"]:checked`).length;

                const counterSpan = document.getElementById(`selected-count-${skill}`);
                if (counterSpan) {
                    counterSpan.textContent = selectedCount;
                    counterSpan.style.color = selectedCount === targetCount ? '#16a34a' : '#ef4444';
                }

                if (selectedCount > targetCount) {
                    // Checkboxes shouldn't let them go over, but realistically just cap it visually by disabling unchecked ones
                }

                if (selectedCount >= targetCount) {
                    checkboxes.forEach(cb => {
                        if (!cb.checked) cb.disabled = true;
                    });
                } else {
                    checkboxes.forEach(cb => cb.disabled = false);
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                if (typeof targetCounts !== 'undefined') {
                    Object.keys(targetCounts).forEach(skill => {
                        enforceLimits(skill, targetCounts[skill]);
                    });
                }
            });

            async function generateMoreForSkill(skill) {
                showLoading(`Generating more AI options for ${skill}...`);
                try {
                    const response = await fetch(`/api/jobs/${jobId}/suggestions/generate-more`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ skill, count: 2, difficulty: 'Medium' })
                    });
                    const result = await response.json();
                    if (result.success) {
                        alert(`New options generated for ${skill}!`);
                        location.reload();
                    } else {
                        alert('Error: ' + result.error);
                    }
                } catch (error) {
                    alert('Error generating questions: ' + error.message);
                } finally {
                    hideLoading();
                }
            }

            async function refreshSkillPool(skill) {
                try {
                    const res = await fetch(`/api/jobs/${jobId}/pool/refresh-skill`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ skill })
                    });
                    const result = await res.json();
                    if (result.success) {
                        renderTechnicalAssessment(result.data);
                        showToast(`Refreshed questions for ${skill}`);
                    } else alert('Error: ' + (result.error || result.message));
                } catch (e) { console.error(e); alert('Failed to refresh pool'); }
            }


