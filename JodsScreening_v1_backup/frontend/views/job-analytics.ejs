<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | ScenarioSim
    </title>
    <link rel="stylesheet" href="/css/style.css?v=9">
    <style>
        /* ── Analytics Layout ───────────────── */
        .analytics-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        @media (max-width: 900px) {
            .analytics-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 560px) {
            .analytics-grid {
                grid-template-columns: 1fr;
            }
        }

        .metric-card {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 20px;
            text-align: center;
        }

        .metric-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 8px;
        }

        .metric-value {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--primary-color);
            line-height: 1;
        }

        /* ── Chart Sections ─────────────────── */
        .chart-section {
            background: #ffffff;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 24px;
            margin-bottom: 24px;
        }

        .chart-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-main);
            margin: 0 0 20px;
        }

        /* ── Bar Chart ──────────────────────── */
        .bar-chart {
            display: flex;
            align-items: flex-end;
            gap: 12px;
            height: 180px;
            padding-top: 20px;
            border-bottom: 2px solid var(--border);
        }

        .bar-wrapper {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            height: 100%;
            justify-content: flex-end;
        }

        .bar {
            width: 100%;
            min-height: 4px;
            background: linear-gradient(to top, var(--primary-color), #60a5fa);
            border-radius: 6px 6px 0 0;
            position: relative;
            transition: opacity 0.2s;
        }

        .bar:hover {
            opacity: 0.85;
        }

        .bar:hover::after {
            content: attr(data-value);
            position: absolute;
            top: -26px;
            left: 50%;
            transform: translateX(-50%);
            background: var(--primary-color);
            color: #fff;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            white-space: nowrap;
        }

        .bar-label {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        /* ── Funnel / Conversion ────────────── */
        .conversion-funnel {
            display: flex;
            flex-direction: column;
            gap: 14px;
        }

        .funnel-step {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .funnel-label {
            width: 170px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text-main);
            flex-shrink: 0;
        }

        .funnel-bar {
            flex: 1;
            height: 36px;
            background: #f1f5f9;
            border-radius: 6px;
            overflow: hidden;
        }

        .funnel-fill {
            height: 100%;
            background: linear-gradient(to right, var(--primary-color), #60a5fa);
            border-radius: 6px;
            min-width: 4px;
        }

        .funnel-value {
            width: 55px;
            text-align: right;
            font-size: 0.9rem;
            font-weight: 700;
            color: var(--primary-color);
        }

        /* ── Skill Bars ─────────────────────── */
        .skill-gap-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .skill-gap-item {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .skill-name {
            width: 140px;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
            flex-shrink: 0;
        }

        .skill-performance-bar {
            flex: 1;
            height: 10px;
            background: #eff6ff;
            border-radius: 5px;
            overflow: hidden;
        }

        .skill-performance-fill {
            height: 100%;
            background: linear-gradient(to right, var(--primary-color), #34d399);
            border-radius: 5px;
            min-width: 4px;
        }

        .skill-avg-label {
            width: 48px;
            text-align: right;
            font-size: 0.875rem;
            font-weight: 700;
            color: var(--primary-color);
        }

        /* two-column bottom section */
        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
        }

        @media (max-width: 768px) {
            .bottom-grid {
                grid-template-columns: 1fr;
            }
        }

        /* mini metric cards inside conversion */
        .mini-metrics {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 20px;
        }

        .mini-card {
            background: #f8fafc;
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 14px;
            text-align: center;
        }

        .mini-card .metric-value {
            font-size: 1.6rem;
        }
    </style>
</head>

<body class="has-sidebar">
    <%- include('partials/_navbar') %>

        <div class="main-wrapper">
            <div class="container">

                <!-- Page Header -->
                <div
                    style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px;">
                    <div>
                        <h1 style="color: var(--text-main); margin: 0 0 4px;">Performance Analytics</h1>
                        <p style="color: var(--text-muted); margin: 0;">
                            <%= job.title %> &bull; <em>
                                    <%= job.department %>
                                </em>
                        </p>
                    </div>
                    <a href="/api/jobs/dashboard" class="btn btn-secondary">← Back to Dashboard</a>
                </div>

                <!-- Top Metric Cards -->
                <div class="analytics-grid">
                    <div class="metric-card">
                        <div class="metric-label">Job Views</div>
                        <div class="metric-value">
                            <%= analytics.views %>
                        </div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Applications</div>
                        <div class="metric-value">
                            <%= analytics.applications %>
                        </div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Assessments Done</div>
                        <div class="metric-value">
                            <%= analytics.completedAssessments %>
                        </div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Shortlisted</div>
                        <div class="metric-value">
                            <%= analytics.shortlisted %>
                        </div>
                    </div>
                </div>

                <!-- Actionable Pool Insights -->
                <% if (analytics.insights && analytics.insights.length> 0) { %>
                    <div class="chart-section"
                        style="background: #f8fafc; border-left: 5px solid var(--primary-color);">
                        <h2 class="chart-title" style="display: flex; align-items: center; gap: 10px;">
                            <span>💡</span> Pool Recommendations & Key Findings
                        </h2>
                        <div
                            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px;">
                            <% analytics.insights.forEach(insight=> { %>
                                <div
                                    style="padding: 15px; border-radius: 10px; border: 1px solid var(--border); background: white;">
                                    <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                                        <% if (insight.type==='warning' ) { %>
                                            <span style="color: #f59e0b; font-size: 1.2rem;">⚠️</span>
                                            <% } else if (insight.type==='success' ) { %>
                                                <span style="color: #10b981; font-size: 1.2rem;">✅</span>
                                                <% } else { %>
                                                    <span
                                                        style="color: var(--primary-color); font-size: 1.2rem;">ℹ️</span>
                                                    <% } %>
                                                        <b style="font-size: 0.95rem; color: var(--text-main);">
                                                            <%= insight.title %>
                                                        </b>
                                    </div>
                                    <p
                                        style="margin: 0; font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">
                                        <%= insight.message %>
                                    </p>
                                </div>
                                <% }) %>
                        </div>
                    </div>
                    <% } %>

                        <!-- Skill Proficiency -->
                        <div class="chart-section">
                            <h2 class="chart-title">📊 Skill Proficiency Analysis <span
                                    style="font-weight:400; font-size:0.85rem; color: var(--text-muted);">(Aggregated
                                    across all
                                    candidates)</span></h2>
                            <% if (analytics.skillGapAnalysis && Object.keys(analytics.skillGapAnalysis).length> 0) { %>
                                <div class="skill-gap-list">
                                    <% Object.entries(analytics.skillGapAnalysis).forEach(([skill, avg])=> { %>
                                        <div class="skill-gap-item">
                                            <div class="skill-name">
                                                <%= skill %>
                                            </div>
                                            <div class="skill-performance-bar">
                                                <div class="skill-performance-fill" data-pct="<%= avg %>"></div>
                                            </div>
                                            <div class="skill-avg-label">
                                                <%= avg %>%
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>
                                <% } else { %>
                                    <p style="color: var(--text-muted); text-align: center; padding: 2rem;">
                                        No skill data available yet. Data appears once candidates complete assessments.
                                    </p>
                                    <% } %>
                        </div>

                        <!-- Bottom: Score Distribution + Conversion -->
                        <div class="bottom-grid">

                            <!-- Score Distribution -->
                            <div class="chart-section">
                                <h2 class="chart-title">📈 Score Distribution <span
                                        style="font-weight:400; font-size:0.85rem; color: var(--text-muted);">(Weighted)</span>
                                </h2>
                                <% const distro=analytics.scoreDistribution || {}; const values=Object.values(distro);
                                    const maxCount=values.length> 0 ? Math.max(...values, 1) : 1;
                                    %>
                                    <div class="bar-chart">
                                        <div class="bar-wrapper">
                                            <div class="bar"
                                                data-pct="<%= Math.max(((distro['<50'] || 0) / maxCount) * 100, 2) %>"
                                                data-value="<%= distro['<50'] || 0 %>"></div>
                                            <div class="bar-label">&lt;50</div>
                                        </div>
                                        <div class="bar-wrapper">
                                            <div class="bar"
                                                data-pct="<%= Math.max(((distro['50-70'] || 0) / maxCount) * 100, 2) %>"
                                                data-value="<%= distro['50-70'] || 0 %>"></div>
                                            <div class="bar-label">50–70</div>
                                        </div>
                                        <div class="bar-wrapper">
                                            <div class="bar"
                                                data-pct="<%= Math.max(((distro['70-85'] || 0) / maxCount) * 100, 2) %>"
                                                data-value="<%= distro['70-85'] || 0 %>"></div>
                                            <div class="bar-label">70–85</div>
                                        </div>
                                        <div class="bar-wrapper">
                                            <div class="bar"
                                                data-pct="<%= Math.max(((distro['>85'] || 0) / maxCount) * 100, 2) %>"
                                                data-value="<%= distro['>85'] || 0 %>"></div>
                                            <div class="bar-label">&gt;85</div>
                                        </div>
                                    </div>
                            </div>

                            <!-- Conversion Rates -->
                            <div class="chart-section">
                                <h2 class="chart-title">🔄 Conversion Rates</h2>
                                <div class="conversion-funnel">
                                    <div class="funnel-step">
                                        <div class="funnel-label">Apply → Complete</div>
                                        <div class="funnel-bar">
                                            <div class="funnel-fill"
                                                data-pct="<%= analytics.conversionRates.applyToComplete %>"></div>
                                        </div>
                                        <div class="funnel-value">
                                            <%= analytics.conversionRates.applyToComplete %>%
                                        </div>
                                    </div>
                                    <div class="funnel-step">
                                        <div class="funnel-label">Complete → Shortlist</div>
                                        <div class="funnel-bar">
                                            <div class="funnel-fill"
                                                data-pct="<%= analytics.conversionRates.completeToShortlist %>"></div>
                                        </div>
                                        <div class="funnel-value">
                                            <%= analytics.conversionRates.completeToShortlist %>%
                                        </div>
                                    </div>
                                </div>

                                <div class="mini-metrics">
                                    <div class="mini-card">
                                        <div class="metric-label">Avg Tech Score</div>
                                        <div class="metric-value">
                                            <%= analytics.avgTechnicalScore %>%
                                        </div>
                                    </div>
                                    <div class="mini-card">
                                        <div class="metric-label">Avg Soft Skill</div>
                                        <div class="metric-value">
                                            <%= analytics.avgSoftSkillScore %>%
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
            </div>
        </div>
</body>

<script>
    // Apply data-pct values as width/height inline styles (avoids CSS linter errors with EJS)
    document.querySelectorAll('[data-pct]').forEach(el => {
        const val = parseFloat(el.getAttribute('data-pct')) || 0;
        if (el.classList.contains('bar')) {
            el.style.height = val + '%';
        } else {
            el.style.width = val + '%';
        }
    });
</script>

</html>