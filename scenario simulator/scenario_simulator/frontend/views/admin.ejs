<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Command Center</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 30px;
            border-bottom: 2px solid var(--border);
        }

        .tab {
            padding: 12px 24px;
            cursor: pointer;
            color: var(--text-muted);
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
        }

        .tab.active {
            color: var(--primary-color);
            border-bottom-color: var(--primary-color);
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .scenario-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 20px;
        }

        .scenario-card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .scenario-card h4 {
            margin: 0 0 10px 0;
            color: var(--text-main);
        }

        .scenario-card .actions {
            display: flex;
            gap: 10px;
            margin-top: 15px;
        }

        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            overflow-y: auto;
        }

        .modal-content {
            background: var(--card-bg);
            margin: 50px auto;
            padding: 30px;
            border-radius: 16px;
            max-width: 800px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .ai-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9em;
            transition: transform 0.2s;
        }

        .ai-btn:hover {
            transform: scale(1.05);
        }

        .ai-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .confidence-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.75em;
            margin-left: 8px;
        }

        .confidence-high {
            background: #10b981;
            color: white;
        }

        .confidence-medium {
            background: #f59e0b;
            color: white;
        }

        .confidence-low {
            background: #ef4444;
            color: white;
        }

        .option-row {
            display: grid;
            grid-template-columns: 1fr 80px 100px auto;
            gap: 10px;
            align-items: center;
            margin-bottom: 10px;
        }

        .stage-item {
            background: rgba(255, 255, 255, 0.02);
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            position: relative;
            border: 1px solid var(--border);
        }

        .remove-btn {
            position: absolute;
            top: 10px;
            right: 10px;
            color: var(--danger);
            cursor: pointer;
            font-size: 0.9em;
            padding: 4px 12px;
            background: rgba(239, 68, 68, 0.1);
            border-radius: 6px;
        }

        .refine-btn {
            background: transparent;
            border: 1px solid var(--primary-color);
            color: var(--primary-color);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.8em;
            cursor: pointer;
            transition: all 0.2s;
            margin-left: 5px;
        }

        .refine-btn:hover {
            background: rgba(99, 102, 241, 0.1);
        }

        .audit-panel {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--border);
            padding: 15px;
            border-radius: 12px;
            margin-top: 20px;
            display: none;
        }

        .audit-issue {
            padding: 8px;
            border-radius: 6px;
            margin-bottom: 8px;
            font-size: 0.85em;
        }

        .audit-warning {
            background: rgba(245, 158, 11, 0.1);
            color: #f59e0b;
            border-left: 3px solid #f59e0b;
        }

        .audit-critical {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-left: 3px solid #ef4444;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
            background: var(--card-bg);
            border-radius: 12px;
            overflow: hidden;
        }

        th,
        td {
            padding: 16px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }

        th {
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-muted);
            font-size: 0.85em;
            text-transform: uppercase;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-muted);
            font-size: 0.9em;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border);
            border-radius: 8px;
            color: var(--text-main);
            font-family: inherit;
        }

        .ai-suggestion-modal {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 12px;
            margin-top: 10px;
            border: 2px solid #667eea;
        }

        .suggestion-option {
            padding: 12px;
            margin: 8px 0;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 8px;
            cursor: pointer;
            border: 1px solid transparent;
            transition: all 0.2s;
        }

        .suggestion-option:hover {
            border-color: var(--primary-color);
            background: rgba(102, 126, 234, 0.1);
        }
    </style>
</head>

<body>
    <div class="navbar">
        <h2>SimPlatform Admin</h2>
        <div id="nav-links">
            <!-- Navbar built via main.js -->
        </div>
    </div>

    <div class="container" style="max-width: 1400px;">
        <h1>Admin Command Center</h1>
        <p style="color: var(--text-muted); margin-bottom: 10px;">Manage users, scenarios, and system configuration</p>

        <!-- AI Status Indicator -->
        <div id="global-ai-status"
            style="display: none; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); padding: 8px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 0.9em; animation: fadeIn 0.5s;">
            <span style="color: var(--text-muted);">🛰️ Connected AI: </span>
            <strong id="active-model-name" style="color: #10b981;">Gemini 2.0 Flash</strong>
            <span id="ai-status-badge"
                style="margin-left: 10px; font-size: 0.8em; padding: 2px 6px; border-radius: 4px; background: #10b981; color: white;">ACTIVE</span>
        </div>

        <!-- Tabs -->
        <div class="tabs">
            <div class="tab active" onclick="switchTab('users')">👥 User Management</div>
            <div class="tab" onclick="switchTab('scenarios')">📋 Scenario Management</div>
        </div>

        <!-- User Management Tab -->
        <div id="users-tab" class="tab-content active">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>User Management</h2>
                <button class="btn" onclick="openCreateUserModal()">+ Create User</button>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Job Role</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="userTableBody">
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 40px;">Loading...</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Scenario Management Tab -->
        <div id="scenarios-tab" class="tab-content">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                <h2>Scenario Management</h2>
                <button class="btn" onclick="openScenarioEditor(null)">+ Create Scenario</button>
            </div>

            <div id="scenarioRoles">
                <!-- Will be populated with role sections -->
            </div>
        </div>
    </div>

    <!-- Create/Edit User Modal -->
    <div id="userModal" class="modal">
        <div class="modal-content" style="max-width: 500px;">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2 id="userModalTitle">Create User</h2>
                <span onclick="closeUserModal()" style="cursor:pointer; font-size:1.5em;">&times;</span>
            </div>
            <form id="userForm">
                <div class="form-group">
                    <label>Name</label>
                    <input type="text" id="userName" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="userEmail" required>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" id="userPassword" minlength="6">
                    <small style="color: var(--text-muted);">Leave blank to keep current password</small>
                </div>
                <div class="form-group">
                    <label>Role</label>
                    <select id="userRole">
                        <option value="employee">Employee</option>
                        <option value="manager">Manager</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Target Job Role (For Simulations)</label>
                    <select id="userJobRole">
                        <option value="None">None</option>
                        <option value="Developer">Developer</option>
                        <option value="Team Lead">Team Lead</option>
                        <option value="Project Manager">Project Manager</option>
                        <option value="HR">HR</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Access Authorization</label>
                    <select id="userIsAuthorized">
                        <option value="true">Authorized</option>
                        <option value="false">Awaiting Authorization / Blocked</option>
                    </select>
                </div>
                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" class="btn btn-secondary" onclick="closeUserModal()">Cancel</button>
                    <button type="submit" class="btn">Save</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scenario Editor Modal -->
    <div id="scenarioModal" class="modal">
        <div class="modal-content">
            <div style="display:flex; justify-content:space-between; margin-bottom:20px;">
                <h2 id="scenarioModalTitle">Create Scenario</h2>
                <span onclick="closeScenarioModal()" style="cursor:pointer; font-size:1.5em;">&times;</span>
            </div>
            <form id="scenarioForm">
                <input type="hidden" id="scenarioId">

                <div class="grid-2">
                    <div class="form-group">
                        <label>Title</label>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            <input type="text" id="scenarioTitle" required style="flex: 1;">
                            <button type="button" class="ai-btn" onclick="generateTitles()">🤖 Generate</button>
                            <button type="button" class="refine-btn" onclick="refineField('scenarioTitle', 'Title')">✨
                                Refine</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Job Role</label>
                        <select id="scenarioRole" required>
                            <option value="Developer">Developer</option>
                            <option value="Team Lead">Team Lead</option>
                            <option value="Project Manager">Project Manager</option>
                            <option value="HR">HR</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Difficulty</label>
                    <select id="scenarioDifficulty" required>
                        <option value="Easy">Easy</option>
                        <option value="Medium">Medium</option>
                        <option value="Hard">Hard</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <div style="display: flex; gap: 10px; flex-direction: column;">
                        <textarea id="scenarioDescription" rows="4" required></textarea>
                        <div style="display: flex; gap: 10px;">
                            <button type="button" class="ai-btn" onclick="generateDescription()">🤖 Generate
                                Description</button>
                            <button type="button" class="refine-btn"
                                onclick="refineField('scenarioDescription', 'Description')">✨ Refine</button>
                        </div>
                    </div>
                </div>

                <h3 style="margin-top: 30px; border-bottom: 1px solid var(--border); padding-bottom: 10px;">Stages</h3>
                <div id="stagesContainer"></div>
                <button type="button" class="btn btn-secondary" onclick="addStage()"
                    style="width: 100%; margin-top: 10px;">+ Add Stage</button>

                <!-- AI Audit Section -->
                <div id="aiAuditPanel" class="audit-panel">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <h4 style="margin: 0; display: flex; align-items: center; gap: 8px;">🛡️ AI System Audit</h4>
                        <button type="button" id="applyFixesBtn" class="refine-btn"
                            style="display: none; border-color: #10b981; color: #10b981;" onclick="applyAIFixes()">🛠️
                            Apply AI Fixes</button>
                    </div>
                    <div id="auditResults"></div>
                    <div id="auditSuggestions" style="margin-top: 10px; font-size: 0.85em; color: var(--text-muted);">
                    </div>
                </div>

                <div
                    style="margin-top: 30px; display: flex; gap: 10px; justify-content: flex-end; align-items: center;">
                    <button type="button" class="ai-btn"
                        style="background: var(--bg-dark); border: 1px solid var(--primary-color);"
                        onclick="runAIAudit()">🔍 Run AI Audit</button>
                    <div style="flex: 1;"></div>
                    <button type="button" class="btn btn-secondary" onclick="closeScenarioModal()">Cancel</button>
                    <button type="submit" class="btn">Save Scenario</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/js/main.js"></script>
    <script>
        let currentUserId = null;
        let currentScenarioId = null;
        let stageCounter = 0;
        let lastAuditReport = null;

        function updateAIStatus(source) {
            const el = document.getElementById('global-ai-status');
            const modelEl = document.getElementById('active-model-name');
            const badge = document.getElementById('ai-status-badge');

            if (source && el && modelEl) {
                modelEl.textContent = `${source.provider} - ${source.model}`;
                if (source.status === 'Fallback') {
                    badge.textContent = 'MOCK FALLBACK';
                    badge.style.background = '#f59e0b';
                    el.style.background = 'rgba(245, 158, 11, 0.1)';
                    el.style.borderColor = 'rgba(245, 158, 11, 0.2)';
                } else {
                    badge.textContent = 'LIVE API';
                    badge.style.background = '#10b981';
                    el.style.background = 'rgba(16, 185, 129, 0.1)';
                    el.style.borderColor = 'rgba(16, 185, 129, 0.2)';
                }
                el.style.display = 'block';
            }
        }

        // Tab Switching
        function switchTab(tab) {
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(tc => tc.classList.remove('active'));

            event.target.classList.add('active');
            document.getElementById(tab + '-tab').classList.add('active');

            if (tab === 'scenarios') loadScenarios();
        }

        // User Management
        async function loadUsers() {
            try {
                const res = await fetch('/api/users', { credentials: 'include' });
                const data = await res.json();
                console.log('Users loaded:', data);

                const tbody = document.getElementById('userTableBody');
                if (!tbody) return;
                tbody.innerHTML = '';

                if (data.success && data.data && data.data.users) {
                    if (data.data.users.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 20px;">No users found</td></tr>';
                        return;
                    }

                    data.data.users.forEach(user => {
                        const tr = document.createElement('tr');
                        tr.innerHTML = `
                            <td>${user.name || 'N/A'}</td>
                            <td>${user.email}</td>
                            <td><span class="badge" style="background: rgba(99,102,241,0.1); color: var(--primary-color);">${user.role.toUpperCase()}</span></td>
                            <td>${user.jobRole || 'None'}</td>
                            <td><span class="badge ${user.isActive ? 'badge-success' : 'badge-danger'}">${user.isActive ? 'Active' : 'Inactive'}</span></td>
                            <td>
                                <div style="display:flex; gap:8px;">
                                    <button class="btn btn-secondary" style="padding: 6px 12px; font-size: 0.85em;" onclick="editUser('${user._id}')">Edit</button>
                                    <button class="btn" style="padding: 6px 12px; font-size: 0.85em; background: rgba(239,68,68,0.2); color: #f87171;" onclick="deleteUser('${user._id}')">Delete</button>
                                </div>
                            </td>
                        `;
                        tbody.appendChild(tr);
                    });
                } else {
                    tbody.innerHTML = `<tr><td colspan="6" style="text-align: center; color: var(--danger);">Error: ${data.error || 'Failed to load users'}</td></tr>`;
                }
            } catch (err) {
                console.error('Failed to load users:', err);
                const tbody = document.getElementById('userTableBody');
                if (tbody) tbody.innerHTML = '<tr><td colspan="6" style="text-align: center; color: var(--danger);">Connection error or unauthorized</td></tr>';
            }
        }

        function openCreateUserModal() {
            currentUserId = null;
            document.getElementById('userModalTitle').textContent = 'Create User';
            document.getElementById('userForm').reset();
            document.getElementById('userPassword').required = true;
            document.getElementById('userModal').style.display = 'block';
        }

        async function editUser(id) {
            currentUserId = id;
            document.getElementById('userModalTitle').textContent = 'Edit User';
            document.getElementById('userPassword').required = false;

            try {
                const res = await fetch(`/api/users`, { credentials: 'include' });
                const data = await res.json();
                const user = data.data.users.find(u => u._id === id);

                if (user) {
                    document.getElementById('userName').value = user.name || '';
                    document.getElementById('userEmail').value = user.email || '';
                    document.getElementById('userRole').value = user.role;
                    document.getElementById('userJobRole').value = user.jobRole || 'None';
                    document.getElementById('userIsAuthorized').value = user.isAuthorized.toString();
                    document.getElementById('userModal').style.display = 'block';
                }
            } catch (err) {
                console.error('Failed to fetch user details:', err);
                alert('Failed to load user data');
            }
        }

        async function deleteUser(id) {
            const currentUser = JSON.parse(localStorage.getItem('user'));
            if (currentUser && currentUser.id === id) {
                return alert('You cannot delete your own account while logged in.');
            }

            if (!confirm('Are you sure you want to delete this user? This will deactivate their account.')) return;

            try {
                const res = await fetch(`/api/users/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (res.ok) {
                    alert('User deactivated successfully');
                    loadUsers();
                } else {
                    const data = await res.json();
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                alert('Failed to delete user');
            }
        }

        function closeUserModal() {
            document.getElementById('userModal').style.display = 'none';
        }

        document.getElementById('userForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const payload = {
                name: document.getElementById('userName').value,
                email: document.getElementById('userEmail').value,
                role: document.getElementById('userRole').value,
                jobRole: document.getElementById('userJobRole').value,
                isAuthorized: document.getElementById('userIsAuthorized').value === 'true'
            };

            const password = document.getElementById('userPassword').value;
            if (password) payload.password = password;

            try {
                const url = currentUserId ? `/api/users/${currentUserId}` : '/api/users';
                const method = currentUserId ? 'PUT' : 'POST';

                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                    credentials: 'include'
                });

                if (res.ok) {
                    alert(currentUserId ? 'User updated' : 'User created');
                    closeUserModal();
                    loadUsers();
                } else {
                    const data = await res.json();
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                alert('Failed to save user');
            }
        });

        // Scenario Management
        async function loadScenarios() {
            try {
                const res = await fetch('/api/scenarios', { credentials: 'include' });
                const data = await res.json();

                const container = document.getElementById('scenarioRoles');
                container.innerHTML = '';

                const roles = ['Developer', 'Team Lead', 'Project Manager', 'HR'];
                const difficulties = ['Easy', 'Medium', 'Hard'];

                roles.forEach(role => {
                    const roleSection = document.createElement('div');
                    roleSection.style.marginBottom = '40px';
                    roleSection.innerHTML = `<h3 style="margin-bottom: 20px;">${role}</h3>`;

                    const grid = document.createElement('div');
                    grid.className = 'scenario-grid';

                    difficulties.forEach(diff => {
                        const scenario = data.data.find(s => s.jobRole === role && s.difficulty === diff);

                        const card = document.createElement('div');
                        card.className = 'scenario-card';

                        if (scenario) {
                            card.innerHTML = `
                                <span class="badge badge-${diff === 'Easy' ? 'success' : diff === 'Medium' ? 'warning' : 'danger'}">${diff}</span>
                                <h4 style="margin-top: 10px;">${scenario.title}</h4>
                                <p style="color: var(--text-muted); font-size: 0.9em; margin: 10px 0;">${scenario.description.substring(0, 100)}...</p>
                                <div class="actions">
                                    <button class="btn btn-secondary" style="flex: 1;" onclick="openScenarioEditor('${scenario._id}')">Edit</button>
                                    <button class="btn" style="flex: 1; background: rgba(239,68,68,0.2); color: #f87171;" onclick="deleteScenario('${scenario._id}')">Delete</button>
                                </div>
                            `;
                        } else {
                            card.innerHTML = `
                                <span class="badge">${diff}</span>
                                <h4 style="margin-top: 10px; color: var(--text-muted);">No Scenario</h4>
                                <p style="color: var(--text-muted); font-size: 0.9em; margin: 10px 0;">Create a scenario for this slot</p>
                                <button class="btn" style="width: 100%;" onclick="openScenarioEditor(null, '${role}', '${diff}')">+ Create</button>
                            `;
                        }

                        grid.appendChild(card);
                    });

                    roleSection.appendChild(grid);
                    container.appendChild(roleSection);
                });
            } catch (err) {
                console.error('Failed to load scenarios:', err);
            }
        }

        async function openScenarioEditor(id, presetRole = null, presetDiff = null) {
            currentScenarioId = id;
            document.getElementById('scenarioModalTitle').textContent = id ? 'Edit Scenario' : 'Create Scenario';
            document.getElementById('scenarioForm').reset();
            document.getElementById('stagesContainer').innerHTML = '';
            stageCounter = 0;

            if (presetRole) document.getElementById('scenarioRole').value = presetRole;
            if (presetDiff) document.getElementById('scenarioDifficulty').value = presetDiff;

            if (id) {
                // Load scenario data
                try {
                    const res = await fetch(`/api/scenarios/${id}`, { credentials: 'include' });
                    const data = await res.json();

                    if (data.success) {
                        const s = data.data;
                        document.getElementById('scenarioId').value = s._id;
                        document.getElementById('scenarioTitle').value = s.title;
                        document.getElementById('scenarioRole').value = s.jobRole;
                        document.getElementById('scenarioDifficulty').value = s.difficulty;
                        document.getElementById('scenarioDescription').value = s.description;

                        s.stages.forEach((stage, idx) => {
                            addStage(stage);
                        });
                    }
                } catch (err) {
                    console.error('Failed to load scenario:', err);
                }
            } else {
                addStage();
            }

            document.getElementById('scenarioModal').style.display = 'block';
        }

        function closeScenarioModal() {
            document.getElementById('scenarioModal').style.display = 'none';
        }

        async function deleteScenario(id) {
            if (!confirm('Are you sure you want to delete this scenario?')) return;

            try {
                const res = await fetch(`/api/scenarios/${id}`, {
                    method: 'DELETE',
                    credentials: 'include'
                });

                if (res.ok) {
                    alert('Scenario deleted');
                    loadScenarios();
                }
            } catch (err) {
                alert('Failed to delete scenario');
            }
        }

        function addStage(stageData = null) {
            const container = document.getElementById('stagesContainer');
            const stageId = stageCounter++;

            const stageDiv = document.createElement('div');
            stageDiv.className = 'stage-item';
            stageDiv.dataset.stageId = stageId;

            stageDiv.innerHTML = `
                <span class="remove-btn" onclick="this.parentElement.remove()">Remove</span>
                
                <div class="form-group">
                    <label>Stage Type</label>
                    <select class="stage-type" onchange="updateStageType(${stageId})">
                        <option value="text" ${stageData?.type === 'text' ? 'selected' : ''}>Text Response</option>
                        <option value="mcq" ${stageData?.type === 'mcq' ? 'selected' : ''}>Multiple Choice</option>
                        <option value="ranking" ${stageData?.type === 'ranking' ? 'selected' : ''}>Ranking</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Question/Prompt</label>
                    <div style="display: flex; gap: 10px;">
                        <input type="text" class="stage-prompt" value="${stageData?.prompt || ''}" required style="flex: 1;">
                        <div style="display: flex; gap: 5px;">
                            <button type="button" class="ai-btn" onclick="generateQuestion(${stageId})">🤖 AI</button>
                            <button type="button" class="refine-btn" onclick="refineStagePrompt(${stageId})">✨ Refine</button>
                        </div>
                    </div>
                </div>

                <div class="stage-options" style="display: ${stageData?.type === 'text' ? 'none' : 'block'};">
                    <label>Options</label>
                    <div class="options-container"></div>
                    <button type="button" class="btn btn-secondary" onclick="addOption(${stageId})" style="margin-top: 10px;">+ Add Option</button>
                    <button type="button" class="ai-btn" onclick="generateOptions(${stageId})" style="margin-top: 10px; margin-left: 10px;">🤖 Generate All Options</button>
                </div>
            `;

            container.appendChild(stageDiv);

            if (stageData && stageData.type !== 'text' && stageData.options) {
                stageData.options.forEach((opt, idx) => {
                    const weight = stageData.scoreWeights?.find(sw => sw.option === opt);
                    addOption(stageId, opt, weight?.score || 5, weight?.competencies || []);
                });
            } else if (stageData?.type !== 'text') {
                addOption(stageId);
            }
        }

        function updateStageType(stageId) {
            const stageDiv = document.querySelector(`[data-stage-id="${stageId}"]`);
            const type = stageDiv.querySelector('.stage-type').value;
            const optionsDiv = stageDiv.querySelector('.stage-options');

            optionsDiv.style.display = type === 'text' ? 'none' : 'block';
        }

        function addOption(stageId, text = '', score = 5, competencies = []) {
            const stageDiv = document.querySelector(`[data-stage-id="${stageId}"]`);
            const container = stageDiv.querySelector('.options-container');

            const optionDiv = document.createElement('div');
            optionDiv.className = 'option-row';
            optionDiv.innerHTML = `
                <input type="text" class="option-text" value="${text}" placeholder="Option text" required>
                <input type="number" class="option-score" value="${score}" min="0" max="10" placeholder="Score">
                <button type="button" class="ai-btn" onclick="suggestScore(this)" style="padding: 6px 12px;">🤖 Score</button>
                <button type="button" class="btn" onclick="this.parentElement.remove()" style="padding: 6px 12px; background: rgba(239,68,68,0.2); color: #f87171;">Remove</button>
            `;

            container.appendChild(optionDiv);
        }

        // AI Generation Functions
        async function generateTitles() {
            const role = document.getElementById('scenarioRole').value;
            const difficulty = document.getElementById('scenarioDifficulty').value;

            try {
                const res = await fetch('/api/ai/generate-titles', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ role, difficulty }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success && data.data.suggestions) {
                    updateAIStatus(data.data.aiSource);
                    showSuggestions(data.data.suggestions, (selected) => {
                        document.getElementById('scenarioTitle').value = selected.title;
                    });
                }
            } catch (err) {
                alert('Failed to generate titles');
            }
        }

        async function generateDescription() {
            const role = document.getElementById('scenarioRole').value;
            const difficulty = document.getElementById('scenarioDifficulty').value;
            const title = document.getElementById('scenarioTitle').value;

            if (!title) {
                alert('Please enter a title first');
                return;
            }

            try {
                const res = await fetch('/api/ai/generate-description', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ role, difficulty, title }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success) {
                    updateAIStatus(data.data.aiSource);
                    document.getElementById('scenarioDescription').value = data.data.description;
                }
            } catch (err) {
                alert('Failed to generate description');
            }
        }

        async function generateQuestion(stageId) {
            const description = document.getElementById('scenarioDescription').value;
            const stageDiv = document.querySelector(`[data-stage-id="${stageId}"]`);
            const stageType = stageDiv.querySelector('.stage-type').value;

            // Collect previous stages for chaining
            const previousStages = [];
            let currentReached = false;
            document.querySelectorAll('.stage-item').forEach(div => {
                if (div === stageDiv) {
                    currentReached = true;
                    return;
                }
                if (!currentReached) {
                    const val = div.querySelector('.stage-prompt').value;
                    if (val) previousStages.push(val);
                }
            });

            if (!description) {
                alert('Please enter a scenario description first');
                return;
            }

            try {
                const res = await fetch('/api/ai/generate-questions', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ description, stageType, previousStages }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success && data.data.questions) {
                    updateAIStatus(data.data.aiSource);
                    showSuggestions(data.data.questions, (selected) => {
                        stageDiv.querySelector('.stage-prompt').value = selected.text;
                    });
                }
            } catch (err) {
                alert('Failed to generate questions');
            }
        }

        async function generateOptions(stageId) {
            const stageDiv = document.querySelector(`[data-stage-id="${stageId}"]`);
            const question = stageDiv.querySelector('.stage-prompt').value;

            if (!question) {
                alert('Please enter a question first');
                return;
            }

            try {
                const res = await fetch('/api/ai/generate-options', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ question, count: 4 }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success && data.data.options) {
                    updateAIStatus(data.data.aiSource);
                    const container = stageDiv.querySelector('.options-container');
                    container.innerHTML = '';

                    data.data.options.forEach(opt => {
                        addOption(stageId, opt.text, opt.suggestedScore, []);
                    });
                }
            } catch (err) {
                alert('Failed to generate options');
            }
        }

        async function suggestScore(btn) {
            const optionRow = btn.parentElement;
            const optionText = optionRow.querySelector('.option-text').value;

            if (!optionText) {
                alert('Please enter option text first');
                return;
            }

            try {
                const res = await fetch('/api/ai/suggest-score', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ option: optionText }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success) {
                    updateAIStatus(data.data.aiSource);
                    optionRow.querySelector('.option-score').value = data.data.score;
                    alert(`Suggested Score: ${data.data.score}/10\n\nReasoning: ${data.data.reasoning}\n\nModel: ${data.data.aiSource.model}`);
                }
            } catch (err) {
                alert('Failed to suggest score');
            }
        }

        function showSuggestions(suggestions, onSelect) {
            const modal = document.createElement('div');
            modal.className = 'modal';
            modal.style.display = 'block';

            let suggestionsHTML = '';
            suggestions.forEach((sug, idx) => {
                const confidence = sug.confidence || 0.5;
                const confClass = confidence >= 0.8 ? 'confidence-high' : confidence >= 0.6 ? 'confidence-medium' : 'confidence-low';
                const confText = Math.round(confidence * 100) + '%';

                suggestionsHTML += `
                    <div class="suggestion-option" onclick="selectSuggestion(${idx})">
                        <strong>${sug.title || sug.text}</strong>
                        <span class="confidence-badge ${confClass}">${confText}</span>
                        ${sug.reasoning ? `<p style="color: var(--text-muted); font-size: 0.85em; margin-top: 5px;">${sug.reasoning}</p>` : ''}
                    </div>
                `;
            });

            modal.innerHTML = `
                <div class="modal-content" style="max-width: 600px;">
                    <h3>AI Suggestions</h3>
                    ${suggestionsHTML}
                    <button class="btn btn-secondary" onclick="this.closest('.modal').remove()" style="width: 100%; margin-top: 20px;">Cancel</button>
                </div>
            `;

            window.selectSuggestion = (idx) => {
                onSelect(suggestions[idx]);
                modal.remove();
            };

            document.body.appendChild(modal);
        }

        async function refineField(elementId, type) {
            const content = document.getElementById(elementId).value;
            const role = document.getElementById('scenarioRole').value;
            const difficulty = document.getElementById('scenarioDifficulty').value;

            if (!content) return alert('Please enter some text to refine');

            try {
                const res = await fetch('/api/ai/refine-content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type, content, role, difficulty }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success && data.data.refinedContent) {
                    updateAIStatus(data.data.aiSource);
                    if (confirm(`Refinement Suggestion:\n\n"${data.data.refinedContent}"\n\nApply these changes?`)) {
                        document.getElementById(elementId).value = data.data.refinedContent;
                    }
                }
            } catch (err) {
                alert('Failed to refine content');
            }
        }

        async function refineStagePrompt(stageId) {
            const stageDiv = document.querySelector(`[data-stage-id="${stageId}"]`);
            const content = stageDiv.querySelector('.stage-prompt').value;
            const role = document.getElementById('scenarioRole').value;
            const difficulty = document.getElementById('scenarioDifficulty').value;

            // Collect previous stages for chaining
            const previousStages = [];
            let currentReached = false;
            document.querySelectorAll('.stage-item').forEach(div => {
                if (div === stageDiv) {
                    currentReached = true;
                    return;
                }
                if (!currentReached) {
                    const val = div.querySelector('.stage-prompt').value;
                    if (val) previousStages.push(val);
                }
            });

            if (!content) return alert('Please enter some text to refine');

            try {
                const res = await fetch('/api/ai/refine-content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ type: 'Question', content, role, difficulty, previousStages }),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success && data.data.refinedContent) {
                    updateAIStatus(data.data.aiSource);
                    if (confirm(`Refinement Suggestion:\n\n"${data.data.refinedContent}"\n\nApply these changes?`)) {
                        stageDiv.querySelector('.stage-prompt').value = data.data.refinedContent;
                    }
                }
            } catch (err) {
                alert('Failed to refine prompt');
            }
        }

        async function runAIAudit() {
            const stages = [];
            document.querySelectorAll('.stage-item').forEach(stageDiv => {
                const type = stageDiv.querySelector('.stage-type').value;
                const prompt = stageDiv.querySelector('.stage-prompt').value;
                const options = Array.from(stageDiv.querySelectorAll('.option-text')).map(opt => opt.value);
                stages.push({ type, prompt, options });
            });

            const payload = {
                title: document.getElementById('scenarioTitle').value,
                jobRole: document.getElementById('scenarioRole').value,
                difficulty: document.getElementById('scenarioDifficulty').value,
                description: document.getElementById('scenarioDescription').value,
                stages
            };

            const auditPanel = document.getElementById('aiAuditPanel');

            const resultsDiv = document.getElementById('auditResults');
            const suggestionsDiv = document.getElementById('auditSuggestions');

            auditPanel.style.display = 'block';
            resultsDiv.innerHTML = '<p style="color: var(--primary-color);">Analyzing components...</p>';

            try {
                const res = await fetch('/api/ai/validate-consistency', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success) {
                    updateAIStatus(data.data.aiSource);
                    resultsDiv.innerHTML = '';
                    lastAuditReport = data.data; // Save for applying fixes

                    if (data.data.isConsistent && data.data.mismatches.length === 0) {
                        resultsDiv.innerHTML = '<div class="audit-issue" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">✅ All elements are consistent and aligned.</div>';
                        document.getElementById('applyFixesBtn').style.display = 'none';
                    } else {
                        data.data.mismatches.forEach(m => {
                            const cls = m.severity === 'Critical' ? 'audit-critical' : 'audit-warning';
                            resultsDiv.innerHTML += `<div class="audit-issue ${cls}"><strong>${m.type}:</strong> ${m.issue}</div>`;
                        });
                        document.getElementById('applyFixesBtn').style.display = 'block';
                    }

                    suggestionsDiv.innerHTML = '<strong>AI Recommendations:</strong><ul style="margin-top:5px; padding-left:20px;">' +
                        data.data.suggestions.map(s => `<li>${s}</li>`).join('') + '</ul>';
                }
            } catch (err) {
                resultsDiv.innerHTML = '<p style="color: var(--danger);">Audit failed. Please try again.</p>';
            }
        }

        async function applyAIFixes() {
            if (!lastAuditReport) return;

            const payload = {
                scenario: {
                    title: document.getElementById('scenarioTitle').value,
                    jobRole: document.getElementById('scenarioRole').value,
                    difficulty: document.getElementById('scenarioDifficulty').value,
                    description: document.getElementById('scenarioDescription').value,
                    stages: Array.from(document.querySelectorAll('.stage-item')).map(s => ({
                        prompt: s.querySelector('.stage-prompt').value
                    }))
                },
                auditReport: lastAuditReport
            };

            const btn = document.getElementById('applyFixesBtn');
            const originalText = btn.innerHTML;
            btn.innerHTML = '⏳ Repairing...';
            btn.disabled = true;

            try {
                const res = await fetch('/api/ai/apply-fixes', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                    credentials: 'include'
                });

                const data = await res.json();
                if (data.success) {
                    updateAIStatus(data.data.aiSource);
                    const fixed = data.data;

                    if (confirm(`AI Fixes Ready!\n\nSummary: ${fixed.fixSummary}\n\nWould you like to apply all changes to the form?`)) {
                        document.getElementById('scenarioTitle').value = fixed.title;
                        document.getElementById('scenarioDescription').value = fixed.description;

                        const stageItems = document.querySelectorAll('.stage-item');
                        fixed.stages.forEach((s, i) => {
                            if (stageItems[i]) {
                                stageItems[i].querySelector('.stage-prompt').value = s.prompt;
                            }
                        });

                        alert('Scenario updated! Please run the audit again to verify.');
                        document.getElementById('aiAuditPanel').style.display = 'none';
                    }
                }
            } catch (err) {
                alert('Failed to apply AI fixes');
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        document.getElementById('scenarioForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const stages = [];
            document.querySelectorAll('.stage-item').forEach((stageDiv, idx) => {
                const type = stageDiv.querySelector('.stage-type').value;
                const prompt = stageDiv.querySelector('.stage-prompt').value;

                const stage = {
                    type,
                    prompt,
                    order: idx,
                    options: [],
                    scoreWeights: []
                };

                if (type !== 'text') {
                    stageDiv.querySelectorAll('.option-row').forEach(optRow => {
                        const text = optRow.querySelector('.option-text').value;
                        const score = parseInt(optRow.querySelector('.option-score').value);

                        stage.options.push(text);
                        stage.scoreWeights.push({
                            option: text,
                            score: score,
                            competencies: []
                        });
                    });
                }

                stages.push(stage);
            });

            const payload = {
                title: document.getElementById('scenarioTitle').value,
                jobRole: document.getElementById('scenarioRole').value,
                difficulty: document.getElementById('scenarioDifficulty').value,
                description: document.getElementById('scenarioDescription').value,
                stages
            };

            try {
                const url = currentScenarioId ? `/api/scenarios/${currentScenarioId}` : '/api/scenarios';
                const method = currentScenarioId ? 'PUT' : 'POST';

                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload),
                    credentials: 'include'
                });

                if (res.ok) {
                    alert(currentScenarioId ? 'Scenario updated' : 'Scenario created');
                    closeScenarioModal();
                    loadScenarios();
                } else {
                    const data = await res.json();
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                alert('Failed to save scenario');
            }
        });

        // Load users on page load
        document.addEventListener('DOMContentLoaded', () => {
            loadUsers();
        });
    </script>
</body>

</html>