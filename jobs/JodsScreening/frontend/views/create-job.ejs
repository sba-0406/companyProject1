<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | ScenarioSim
    </title>
    <link rel="stylesheet" href="/css/style.css?v=9">
    <style>
        .form-section {
            padding: 30px;
            border-bottom: 1px solid var(--border);
        }

        .form-section:last-child {
            border-bottom: none;
        }

        .section-header {
            margin-bottom: 25px;
        }

        .section-header h2 {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-header p {
            font-size: 0.88rem;
            color: var(--text-muted);
            margin-top: 5px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
        }

        .form-group label {
            display: block;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-main);
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: 10px;
            font-size: 0.95rem;
            font-family: inherit;
            transition: all 0.2s;
            background: #fff;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }

        .form-group textarea {
            min-height: 120px;
            resize: vertical;
        }

        .checkbox-group {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            background: #f8fafc;
            padding: 20px;
            border-radius: 12px;
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.2s;
        }

        .checkbox-group:hover {
            border-color: var(--secondary-color);
            background: #f1f5f9;
        }

        .checkbox-group input {
            width: 20px;
            height: 20px;
            margin-top: 2px;
            accent-color: var(--primary-color);
        }

        .btn-fancy {
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 10px 15px -3px rgba(30, 58, 138, 0.2);
            text-align: center;
        }

        .btn-fancy:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 20px -5px rgba(30, 58, 138, 0.3);
            filter: brightness(1.1);
        }

        .btn-secondary-fancy {
            background: #fff;
            color: var(--text-main);
            border: 1px solid var(--border);
            padding: 14px 28px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
            text-decoration: none;
        }

        .btn-secondary-fancy:hover {
            background: #f8fafc;
            border-color: var(--text-muted);
        }

        @media (max-width: 640px) {
            .form-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Loading Overlay Styles (Missing in style.css) */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            transition: all 0.3s;
        }

        .loading-overlay.active {
            display: flex;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 4px solid rgba(255, 255, 255, 0.1);
            border-left-color: #fff;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
    </style>
</head>

<body class="has-sidebar">
    <%- include('partials/_navbar') %>

        <div class="main-wrapper">
            <div class="container" style="max-width: 1100px; padding-bottom: 60px;">
                <div class="mb-30">
                    <a href="/api/jobs/dashboard/view" class="btn-text"
                        style="display: inline-flex; align-items: center; gap: 6px; color: var(--text-muted); text-decoration: none; font-weight: 600; font-size: 0.9rem; margin-bottom: 16px; transition: color 0.2s;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M19 12H5M12 19l-7-7 7-7" />
                        </svg>
                        Back to Dashboard
                    </a>
                    <h1 style="font-size: 2.4rem; font-weight: 800; color: var(--text-main); letter-spacing: -0.02em;">
                        Create New Job</h1>
                    <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 4px;">Launch your next talent
                        search with AI-driven precision.</p>
                </div>

                <div class="card"
                    style="padding: 0; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);">
                    <form id="createJobForm">
                        <!-- Basic Information -->
                        <div class="form-section">
                            <div class="section-header"
                                style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <div>
                                    <h2>Basic Details</h2>
                                    <p>Essential information about the role.</p>
                                </div>
                                <button type="button" id="autofill-btn" onclick="autofillForm()"
                                    class="btn-secondary-fancy"
                                    style="padding: 8px 16px; font-size: 0.85rem; display: flex; align-items: center; gap: 8px; border-color: var(--primary-color); color: var(--primary-color); transition: all 0.3s;">
                                    <span id="autofill-icon">✨</span>
                                    <span id="autofill-text">AI Autofill</span>
                                </button>
                            </div>

                            <div class="form-group mb-24">
                                <label for="title">Job Title *</label>
                                <input type="text" id="title" name="title" required
                                    placeholder="e.g., Senior Full Stack Engineer (Node/React)">
                            </div>

                            <div class="form-grid mb-24">
                                <div class="form-group">
                                    <label for="department">Department *</label>
                                    <input type="text" id="department" name="department" required
                                        placeholder="e.g., Product Engineering">
                                </div>
                                <div class="form-group">
                                    <label for="location">Location *</label>
                                    <input type="text" id="location" name="location" required
                                        placeholder="e.g., Mumbai, Remote">
                                </div>
                            </div>

                            <div class="form-grid mb-24">
                                <div class="form-group">
                                    <label for="experienceMin">Min Experience (Years) *</label>
                                    <input type="number" id="experienceMin" name="experienceMin" required min="0"
                                        value="2">
                                </div>
                                <div class="form-group">
                                    <label for="experienceMax">Max Experience (Years) *</label>
                                    <input type="number" id="experienceMax" name="experienceMax" required min="0"
                                        value="5">
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="employmentType">Employment Type *</label>
                                <select id="employmentType" name="employmentType" required>
                                    <option value="Full-time">Full-time</option>
                                    <option value="Part-time">Part-time</option>
                                    <option value="Contract">Contract</option>
                                    <option value="Internship">Internship</option>
                                </select>
                            </div>
                        </div>

                        <!-- Salary & Perks -->
                        <div class="form-section" style="background: #fcfdfe;">
                            <div class="section-header">
                                <h2>Compensation</h2>
                                <p>Attract the best talent with clear budget ranges.</p>
                            </div>

                            <div class="form-grid">
                                <div class="form-group">
                                    <label for="salaryMin">Min Salary (Annual)</label>
                                    <input type="number" id="salaryMin" name="salaryMin" min="0"
                                        placeholder="e.g., 1200000">
                                </div>
                                <div class="form-group">
                                    <label for="salaryMax">Max Salary (Annual)</label>
                                    <input type="number" id="salaryMax" name="salaryMax" min="0"
                                        placeholder="e.g., 2500000">
                                </div>
                                <div class="form-group">
                                    <label for="salaryCurrency">Currency</label>
                                    <select id="salaryCurrency" name="salaryCurrency">
                                        <option value="INR">Indian Rupee (INR)</option>
                                        <option value="USD">US Dollar (USD)</option>
                                        <option value="EUR">Euro (EUR)</option>
                                        <option value="GBP">Pound Sterling (GBP)</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <!-- Job Description -->
                        <div class="form-section">
                            <div class="section-header">
                                <h2>Job Description *</h2>
                                <p>Our AI analyzes this text to extract skills and generate simulations.</p>
                            </div>

                            <div class="form-group">
                                <textarea id="description" name="description" required
                                    placeholder="Paste the full job description here. Our engine works best when you include specific tech stack details and key responsibilities."></textarea>
                                <small style="color: var(--text-muted); display: block; margin-top: 8px;">
                                    Tip: Be specific about technical requirements for better AI question accuracy.
                                </small>
                            </div>
                        </div>

                        <!-- Company Context -->
                        <div class="form-section" style="background: #fcfdfe;">
                            <div class="section-header">
                                <h2>Company Details</h2>
                                <p>Optional info to give candidates more context.</p>
                            </div>

                            <div class="form-group mb-24">
                                <label for="companyName">Company Name</label>
                                <input type="text" id="companyName" name="companyName"
                                    placeholder="e.g., Darwinbox, TechCorp">
                            </div>

                            <div class="form-group mb-24">
                                <label for="companyDescription">About the Company</label>
                                <textarea id="companyDescription" name="companyDescription" style="min-height: 80px;"
                                    placeholder="Vision, mission, or culture snippets..."></textarea>
                            </div>

                            <div class="form-group">
                                <label for="companyWebsite">Website URL</label>
                                <input type="url" id="companyWebsite" name="companyWebsite"
                                    placeholder="https://example.com">
                            </div>
                        </div>

                        <!-- Assessment Configuration -->
                        <div class="form-section">
                            <div class="section-header">
                                <h2>Assessment Configuration</h2>
                                <p>Control how AI generates your candidate simulation.</p>
                            </div>

                            <div class="form-grid mb-24">
                                <div class="form-group">
                                    <label for="questionsPerSkill">Questions Per Skill</label>
                                    <input type="number" id="questionsPerSkill" name="questionsPerSkill" min="1"
                                        max="10" value="3">
                                    <small style="color: var(--text-muted); display: block; margin-top: 4px;">Number of
                                        technical questions to generate for each identified skill.</small>
                                </div>

                                <div class="checkbox-group"
                                    onclick="document.getElementById('allowAIGeneration').click()">
                                    <input type="checkbox" id="allowAIGeneration" name="allowAIGeneration" checked
                                        onclick="event.stopPropagation()">
                                    <div>
                                        <label
                                            style="margin-bottom: 2px; cursor: pointer; font-size: 0.95rem; font-weight: 700;">AI
                                            Question Generation</label>
                                        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">
                                            Automatically generate technical scenarios using AI based on your JD.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Screening Questions -->
                        <div class="form-section" style="background: #fdfcf6;">
                            <div class="section-header">
                                <h2 style="color: #b45309; display: flex; align-items: center; gap: 8px;">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                                    </svg>
                                    Screening Questions
                                </h2>
                                <p>Ask candidates mandatory questions and auto-reject if requirements aren't met.</p>
                            </div>

                            <div id="screening-questions-container"
                                style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px;">
                                <!-- Questions go here -->
                            </div>

                            <button type="button" onclick="addScreeningQuestion()" class="btn-secondary-fancy"
                                style="padding: 10px 20px; font-size: 0.9rem; display: flex; align-items: center; gap: 8px;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                Add Screening Question
                            </button>
                        </div>

                        <!-- Notification Settings -->
                        <div class="form-section" style="background: #f8fafc;">
                            <div class="section-header">
                                <h2>Notification Channels</h2>
                                <p>Choose how you want to be notified about candidate activity.</p>
                            </div>

                            <div class="form-grid">
                                <div class="checkbox-group" onclick="document.getElementById('sendInApp').click()">
                                    <input type="checkbox" id="sendInApp" name="sendInApp" checked
                                        onclick="event.stopPropagation()">
                                    <div>
                                        <label
                                            style="margin-bottom: 2px; cursor: pointer; font-size: 0.95rem; font-weight: 700;">In-App
                                            Notifications</label>
                                        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Receive
                                            alerts in the top bell tray for new applications and assessment results.</p>
                                    </div>
                                </div>

                                <div class="checkbox-group" onclick="document.getElementById('sendEmail').click()">
                                    <input type="checkbox" id="sendEmail" name="sendEmail"
                                        onclick="event.stopPropagation()">
                                    <div>
                                        <label
                                            style="margin-bottom: 2px; cursor: pointer; font-size: 0.95rem; font-weight: 700;">Email
                                            Alerts</label>
                                        <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0;">Receive a
                                            professional email summary whenever a candidate applies or completes a test.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div style="padding: 30px; background: #f1f5f9; display: flex; gap: 20px;">
                            <a href="/api/jobs/dashboard/view" class="btn-secondary-fancy" style="flex: 1;">Cancel</a>
                            <button type="submit" class="btn-fancy" style="flex: 2;">
                                Create Job & Build Assessment ✨
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Loading Overlay -->
        <div class="loading-overlay" id="loading-overlay">
            <div class="loading-content" style="max-width: 400px; text-align: center;">
                <div class="spinner" style="width: 60px; height: 60px; border-width: 6px; margin: 0 auto 24px;"></div>
                <h2 style="color: #fff; font-size: 1.5rem; font-weight: 800; margin-bottom: 12px;">Crafting
                    Assessment...</h2>
                <p style="color: rgba(255, 255, 255, 0.8); font-size: 1rem; line-height: 1.6;">
                    Our AI is currently analyzing your job description to extract core competencies and generate custom
                    technical questions.
                </p>
                <div
                    style="margin-top: 30px; height: 4px; background: rgba(255,255,255,0.2); border-radius: 2px; overflow: hidden;">
                    <div id="progress-bar"
                        style="height: 100%; background: #fff; width: 0%; transition: width 15s linear;"></div>
                </div>
            </div>
        </div>

        <script>
            let screeningQuestionCount = 0;

            async function autofillForm() {
                const title = document.getElementById('title').value;
                const department = document.getElementById('department').value;
                const location = document.getElementById('location').value;
                const experienceMin = document.getElementById('experienceMin').value;
                const experienceMax = document.getElementById('experienceMax').value;
                const employmentType = document.getElementById('employmentType').value;

                if (!title || !department) {
                    alert('Please enter at least a Job Title and Department to use Autofill.');
                    return;
                }

                const btn = document.getElementById('autofill-btn');
                const text = document.getElementById('autofill-text');
                const icon = document.getElementById('autofill-icon');

                // Loading State
                btn.disabled = true;
                btn.style.opacity = '0.7';
                text.textContent = 'Generating...';
                icon.textContent = '⏳';
                icon.style.animation = 'spin 1s linear infinite';

                try {
                    const response = await fetch('/api/jobs/autofill', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ title, department, location, experienceMin, experienceMax, employmentType })
                    });

                    const result = await response.json();
                    if (!result.success) throw new Error(result.error);

                    const data = result.data;

                    // Populate Fields
                    document.getElementById('description').value = data.description;
                    document.getElementById('salaryMin').value = data.salaryMin;
                    document.getElementById('salaryMax').value = data.salaryMax;
                    document.getElementById('salaryCurrency').value = data.salaryCurrency || 'INR';
                    document.getElementById('companyDescription').value = data.companyDescription;

                    // Populate Screening Questions
                    if (data.screeningQuestions && data.screeningQuestions.length > 0) {
                        // Clear existing if any? Or just append? Let's append but highlight.
                        data.screeningQuestions.forEach(sq => {
                            addScreeningQuestion(sq.question, sq.type, sq.isKnockout, sq.expectedAnswer);
                        });
                    }

                    // Success Feedback
                    text.textContent = 'Success!';
                    icon.textContent = '✅';
                    icon.style.animation = 'none';
                    setTimeout(() => {
                        btn.disabled = false;
                        btn.style.opacity = '1';
                        text.textContent = 'AI Autofill';
                        icon.textContent = '✨';
                    }, 2000);

                } catch (error) {
                    console.error('Autofill error:', error);
                    alert('AI Autofill failed: ' + error.message);
                    btn.disabled = false;
                    btn.style.opacity = '1';
                    text.textContent = 'AI Autofill';
                    icon.textContent = '✨';
                    icon.style.animation = 'none';
                }
            }

            function addScreeningQuestion(initialText = '', initialType = 'yes_no', initialKnockout = false, initialExpected = 'Yes') {
                const container = document.getElementById('screening-questions-container');
                const id = `sq-${Date.now()}`;

                const div = document.createElement('div');
                div.className = 'card screening-q-item';
                div.id = id;
                div.style.padding = '20px';
                div.style.border = '1px solid var(--border)';
                div.style.background = '#fff';
                div.style.position = 'relative';

                div.innerHTML = `
                    <button type="button" onclick="removeScreeningQuestion('${id}')" style="position: absolute; top: 10px; right: 10px; background: none; border: none; color: #ef4444; cursor: pointer; padding: 5px;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                    </button>
                    <div class="form-group mb-16">
                        <label style="font-size: 0.75rem;">Question Text</label>
                        <input type="text" class="sq-text" value="${initialText}" placeholder="e.g., Are you willing to relocate?" required style="font-size: 0.9rem; padding: 8px 12px;">
                    </div>
                    <div style="display: flex; gap: 20px; align-items: center;">
                        <div class="form-group" style="flex: 1; margin: 0;">
                            <label style="font-size: 0.75rem;">Response Type</label>
                            <select class="sq-type" onchange="toggleKnockoutOptions('${id}')" style="font-size: 0.85rem; padding: 6px 10px;">
                                <option value="yes_no" ${initialType === 'yes_no' ? 'selected' : ''}>Yes / No</option>
                                <option value="text" ${initialType === 'text' ? 'selected' : ''}>Short Answer</option>
                            </select>
                        </div>
                        <div style="flex: 1; display: flex; align-items: center; gap: 10px; margin-top: 20px;">
                            <input type="checkbox" class="sq-knockout" id="ko-${id}" ${initialKnockout ? 'checked' : ''} onchange="toggleKnockoutOptions('${id}')">
                            <label for="ko-${id}" style="font-size: 0.85rem; margin: 0; cursor: pointer;">Mark as Knockout</label>
                        </div>
                        <div class="sq-expected-container" style="flex: 1; margin: 0; display: ${initialKnockout && initialType === 'yes_no' ? 'block' : 'none'};">
                            <label style="font-size: 0.75rem;">Expected Answer</label>
                            <select class="sq-expected" style="font-size: 0.85rem; padding: 6px 10px;">
                                <option value="Yes" ${initialExpected === 'Yes' ? 'selected' : ''}>Yes</option>
                                <option value="No" ${initialExpected === 'No' ? 'selected' : ''}>No</option>
                            </select>
                        </div>
                    </div>
                `;
                container.appendChild(div);
                screeningQuestionCount++;
            }

            function removeScreeningQuestion(id) {
                document.getElementById(id).remove();
            }

            function toggleKnockoutOptions(id) {
                const item = document.getElementById(id);
                const type = item.querySelector('.sq-type').value;
                const isKnockout = item.querySelector('.sq-knockout').checked;
                const expectedContainer = item.querySelector('.sq-expected-container');

                if (isKnockout && type === 'yes_no') {
                    expectedContainer.style.display = 'block';
                } else {
                    expectedContainer.style.display = 'none';
                }
            }

            document.getElementById('createJobForm').addEventListener('submit', async (e) => {
                e.preventDefault();

                // Prevent double-submission
                const submitBtn = e.target.querySelector('[type=submit]');
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.textContent = 'Creating...';
                }

                const formData = new FormData(e.target);
                const data = Object.fromEntries(formData.entries());

                // Handle screening questions
                const screeningQuestions = [];
                document.querySelectorAll('.screening-q-item').forEach(item => {
                    screeningQuestions.push({
                        question: item.querySelector('.sq-text').value,
                        type: item.querySelector('.sq-type').value,
                        isKnockout: item.querySelector('.sq-knockout').checked,
                        expectedAnswer: item.querySelector('.sq-expected').value
                    });
                });
                data.screeningQuestions = screeningQuestions;

                // Handle checkbox booleans
                data.allowAIGeneration = e.target.allowAIGeneration.checked;

                // Nested notification settings for the Job model
                data.notificationSettings = {
                    sendInApp: e.target.sendInApp.checked,
                    sendEmail: e.target.sendEmail.checked
                };

                // Convert numbers
                data.experienceMin = parseInt(data.experienceMin);
                data.experienceMax = parseInt(data.experienceMax);
                if (data.salaryMin) data.salaryMin = parseInt(data.salaryMin);
                if (data.salaryMax) data.salaryMax = parseInt(data.salaryMax);
                data.questionsPerSkill = parseInt(data.questionsPerSkill);

                let jobId = null;

                try {
                    // Show loading overlay
                    const overlay = document.getElementById('loading-overlay');
                    overlay.classList.add('active');
                    setTimeout(() => {
                        document.getElementById('progress-bar').style.width = '90%';
                    }, 100);

                    // Step 1: Create job
                    const jobResponse = await fetch('/api/jobs', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(data)
                    });

                    const jobResult = await jobResponse.json();

                    if (!jobResult.success) {
                        throw new Error(jobResult.error || 'Failed to create job');
                    }

                    jobId = jobResult.data._id;

                    // Step 2: Generate assessment
                    const assessmentResponse = await fetch(`/api/jobs/${jobId}/generate-assessment`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });

                    const assessmentResult = await assessmentResponse.json();

                    if (!assessmentResult.success) {
                        throw new Error(assessmentResult.error || 'AI Generation failed');
                    }

                    document.getElementById('progress-bar').style.width = '100%';

                    // Allow a small delay for the user to see completion
                    setTimeout(() => {
                        window.location.href = `/api/jobs/${jobId}/view`;
                    }, 800);

                } catch (error) {
                    console.error('Error:', error);

                    // --- Rollback: delete orphan job if assessment failed ---
                    if (jobId) {
                        try {
                            await fetch(`/api/jobs/${jobId}`, { method: 'DELETE' });
                            console.log('Orphan job deleted:', jobId);
                        } catch (deleteErr) {
                            console.warn('Could not clean up orphan job:', deleteErr);
                        }
                    }

                    // Re-enable button
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.textContent = 'Create Job & Generate Assessment';
                    }

                    const isRateLimit = error.message.includes('Rate limit') || error.message.includes('429');
                    alert(isRateLimit
                        ? '⚠️ AI is busy (rate limit reached). Please wait a few minutes and try again. Your job draft was NOT saved.'
                        : 'Error: ' + error.message);

                    document.getElementById('loading-overlay').classList.remove('active');
                    document.getElementById('progress-bar').style.width = '0%';
                }
            });
        </script>
</body>

</html>