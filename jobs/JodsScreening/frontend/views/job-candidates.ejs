<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | ScenarioSim
    </title>
    <link rel="stylesheet" href="/css/style.css?v=12">
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
        }

        .job-tag {
            background: #f1f5f9;
            color: #475569;
            padding: 4px 12px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-left: 10px;
        }

        /* ── Pool Stats Grid ───────────────── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        @media (max-width: 1024px) {
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 640px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ── Table Styling ───────────────── */
        .candidates-table th {
            white-space: nowrap;
        }

        .match-score-pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 800;
            font-size: 1.1rem;
        }

        .score-bar-mini {
            width: 80px;
            height: 8px;
            background: #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            display: inline-block;
        }

        .score-fill {
            height: 100%;
            border-radius: 10px;
        }

        .score-high {
            background: #10b981;
        }

        .score-mid {
            background: #f59e0b;
        }

        .score-low {
            background: #ef4444;
        }

        .rank-circle {
            width: 36px;
            height: 36px;
            background: #f1f5f9;
            color: #64748b;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            margin: 0 auto;
        }

        .rank-top {
            background: #eff6ff;
            color: #2563eb;
        }

        .action-btns {
            display: flex;
            gap: 8px;
            justify-content: flex-end;
        }

        /* ── Segregated Tabs ───────────────── */
        .tabs-container {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            border-bottom: 1px solid var(--border);
            padding-bottom: 2px;
        }

        .tab-btn {
            padding: 10px 24px;
            border: none;
            background: none;
            font-weight: 600;
            color: var(--text-muted);
            cursor: pointer;
            position: relative;
            transition: all 0.2s;
            font-size: 0.95rem;
        }

        .tab-btn:hover {
            color: var(--primary-color);
        }

        .tab-btn.active {
            color: var(--primary-color);
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            right: 0;
            height: 3px;
            background: var(--primary-color);
            border-radius: 3px 3px 0 0;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .count-badge {
            background: #f1f5f9;
            color: #64748b;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.75rem;
            margin-left: 6px;
        }

        .active .count-badge {
            background: #eff6ff;
            color: #2563eb;
        }

        /* ── Skill Match UI ───────────────── */
        .skill-tag-mini {
            display: inline-block;
            background: #ecfdf5;
            color: #059669;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-right: 4px;
            margin-bottom: 4px;
        }

        .skill-missing {
            background: #fef2f2;
            color: #dc2626;
        }

        .match-indicator {
            font-size: 0.75rem;
            font-weight: 700;
            margin-bottom: 4px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .invite-suggest {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #fffbeb;
            color: #92400e;
            padding: 2px 8px;
            border-radius: 12px;
            font-size: 0.7rem;
            font-weight: 700;
            border: 1px solid #fef3c7;
            margin-top: 4px;
        }
    </style>
</head>

<body class="has-sidebar">
    <%- include('partials/_navbar') %>

        <div class="main-wrapper">
            <div class="container">

                <!-- Header -->
                <div class="page-header">
                    <div>
                        <h1 style="margin: 0; display: flex; align-items: center;">
                            Candidates
                            <span class="job-tag">
                                <%= job.title %>
                            </span>
                        </h1>
                        <p style="color: var(--text-muted); margin-top: 5px;">
                            <%= candidates.length %> Total Applicants
                        </p>
                    </div>
                    <a href="/api/jobs/dashboard" class="btn btn-secondary">← Back to Dashboard</a>
                </div>

                <!-- Metrics Grid -->
                <div class="stats-grid">
                    <div class="stat-card" style="border-left: 4px solid var(--primary-color);">
                        <h3>Required Experience</h3>
                        <div class="stat-value" style="font-size: 1.5rem;">
                            <%= job.experienceMin %>–<%= job.experienceMax %> yrs
                        </div>
                    </div>

                    <div class="stat-card" id="pi-avg-card" style="display: none;">
                        <h3>Pool Avg. Score</h3>
                        <div class="stat-value" id="pi-avg-score-val" style="font-size: 1.5rem;">—</div>
                    </div>

                    <div class="stat-card" id="pi-pot-card" style="display: none;">
                        <h3>High Potential</h3>
                        <div class="stat-value" id="pi-high-pot-val" style="font-size: 1.5rem;">—</div>
                    </div>

                    <div class="stat-card" id="pi-exp-card" style="display: none;">
                        <h3>Avg. Experience</h3>
                        <div class="stat-value" id="pi-avg-exp-val" style="font-size: 1.5rem;">—</div>
                    </div>
                </div>

                <!-- Results Section -->
                <div class="tabs-container">
                    <% // Qualified Pool=Assessment Completed OR Finalized (Rejected/Hired) const
                        qualifiedPool=candidates.filter(c=> c.assessmentStatus === 'completed' || ['rejected',
                        'hired'].includes(c.status));
                        // Initial Pool = Active candidates who haven't finished assessment
                        const initialPool = candidates.filter(c => c.assessmentStatus !== 'completed' && !['rejected',
                        'hired'].includes(c.status));
                        %>
                        <button class="tab-btn active" onclick="showTab('qualified-tab')">
                            Qualified Pool (Simulation)
                            <span class="count-badge">
                                <%= qualifiedPool.length %>
                            </span>
                        </button>
                        <button class="tab-btn" onclick="showTab('initial-tab')">
                            Initial Pool (Resume Match)
                            <span class="count-badge">
                                <%= initialPool.length %>
                            </span>
                        </button>
                </div>

                <!-- Tab 1: Qualified Pool -->
                <div id="qualified-tab" class="tab-content active">
                    <div class="filter-bar"
                        style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px; background: #f8fafc; padding: 12px 20px; border-radius: 8px; border: 1px solid var(--border);">
                        <label
                            style="font-size: 0.8rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Filter
                            by Status:</label>
                        <select id="status-filter" onchange="filterCandidates(this.value)"
                            style="padding: 6px 12px; border-radius: 6px; border: 1px solid var(--border); font-size: 0.9rem; font-weight: 600; color: var(--text-main); cursor: pointer; outline: none;">
                            <option value="all">All Qualified</option>
                            <option value="waiting">Waiting for Action</option>
                            <option value="shortlisted">Shortlisted</option>
                            <option value="interview">Interview Scheduled</option>
                            <option value="hired">Hired</option>
                            <option value="rejected">Rejected</option>
                        </select>
                        <span id="filter-count"
                            style="font-size: 0.85rem; color: var(--text-muted); font-weight: 500;">Showing <%=
                                qualifiedPool.length %> candidates</span>
                    </div>

                    <div class="card" style="padding: 0; overflow: hidden;">
                        <table class="candidates-table" id="qualified-table">
                            <thead>
                                <tr>
                                    <th style="width: 80px; text-align: center;">Rank</th>
                                    <th>Candidate</th>
                                    <th>Performance</th>
                                    <th>Status</th>
                                    <th style="text-align: center;">Skill Match</th>
                                    <th>Composite Match</th>
                                    <th style="text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (qualifiedPool.length===0) { %>
                                    <tr>
                                        <td colspan="7" class="empty-state">No candidates have completed the simulation
                                            yet.</td>
                                    </tr>
                                    <% } else { %>
                                        <% qualifiedPool.forEach((candidate, index)=> { %>
                                            <tr class="candidate-row"
                                                data-status="<%= candidate.status || 'applied' %>">
                                                <td style="text-align: center;">
                                                    <% if (candidate.assessmentStatus==='completed' ) { %>
                                                        <div class="rank-circle <%= index < 3 ? 'rank-top' : '' %>">
                                                            <%= index + 1 %>
                                                        </div>
                                                        <% } else { %>
                                                            <div class="rank-circle">—</div>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <div style="font-weight: 700; color: var(--text-main);">
                                                        <%= candidate.candidateName %>
                                                    </div>
                                                    <div style="font-size: 0.8rem; color: var(--text-muted);">
                                                        <%= candidate.candidateEmail %>
                                                    </div>
                                                </td>
                                                <td>
                                                    <% if (candidate.assessmentStatus==='completed' ) { %>
                                                        <div style="font-size: 0.85rem; font-weight: 600;">
                                                            TECH: <%= candidate.assessmentResults?.technicalScore || 0
                                                                %>%
                                                        </div>
                                                        <div
                                                            style="font-size: 0.85rem; font-weight: 600; color: var(--text-muted);">
                                                            SOFT: <%= candidate.assessmentResults?.softSkillScore || 0
                                                                %>%
                                                        </div>
                                                        <% } else { %>
                                                            <div style="font-size: 0.85rem; color: var(--text-muted);">
                                                                No Simulation</div>
                                                            <% } %>
                                                </td>
                                                <td>
                                                    <% let badgeClass='badge-info' ; if
                                                        (candidate.status==='shortlisted' ) badgeClass='badge-success' ;
                                                        if (candidate.status==='interview_scheduled' )
                                                        badgeClass='badge-primary' ; if (candidate.status==='hired' )
                                                        badgeClass='badge-success' ; if (candidate.status==='rejected' )
                                                        badgeClass='badge-danger' ; %>
                                                        <span class="badge <%= badgeClass %>">
                                                            <%= (candidate.status || 'applied'
                                                                ).toUpperCase().replace(/_/g, ' ' ) %>
                                                        </span>
                                                        <% if (candidate.assessmentStatus==='completed' ) { %>
                                                            <div
                                                                style="font-size: 0.7rem; color: var(--text-muted); margin-top: 4px; font-weight: 700; text-transform: uppercase;">
                                                                <%= candidate.assessmentResults?.overallFit || 'N/A' %>
                                                            </div>
                                                            <% } %>
                                                </td>
                                                <td style="text-align: center;">
                                                    <div style="font-weight: 800; color: var(--text-main);">
                                                        <%= candidate.matchMeta?.skillScore || 0 %>%
                                                    </div>
                                                    <div
                                                        style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase;">
                                                        Resume Index</div>
                                                </td>
                                                <td>
                                                    <div class="match-score-pill">
                                                        <span>
                                                            <%= candidate.matchScore || 0 %>%
                                                        </span>
                                                        <div class="score-bar-mini">
                                                            <% const colorClass=(candidate.matchScore || 0)>= 70 ?
                                                                'score-high' : ((candidate.matchScore || 0) >= 50 ?
                                                                'score-mid' : 'score-low'); %>
                                                                <div class="score-fill <%= colorClass %>"
                                                                    style="width: <%= candidate.matchScore || 0 %>%">
                                                                </div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="action-btns">
                                                        <a href="/api/applications/application/<%= candidate._id %>/view"
                                                            class="btn btn-sm btn-secondary">Report</a>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Tab 2: Initial Pool -->
                <div id="initial-tab" class="tab-content">
                    <div class="card" style="padding: 0; overflow: hidden;">
                        <table class="candidates-table shadow-sm">
                            <thead>
                                <tr>
                                    <th style="width: 80px; text-align: center;">Rank</th>
                                    <th>Candidate</th>
                                    <th>Experience</th>
                                    <th>Match Details</th>
                                    <th>Index Score</th>
                                    <th style="text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (initialPool.length===0) { %>
                                    <tr>
                                        <td colspan="6" class="empty-state">All candidates have moved to the Qualified
                                            Pool.</td>
                                    </tr>
                                    <% } else { %>
                                        <% initialPool.sort((a,b)=> (b.matchMeta?.resumeScore || 0) -
                                            (a.matchMeta?.resumeScore || 0));
                                            initialPool.forEach((candidate, index) => {
                                            %>
                                            <tr>
                                                <td style="text-align: center;">
                                                    <div class="rank-circle <%= index < 3 ? 'rank-top' : '' %>">
                                                        <%= index + 1 %>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div style="font-weight: 700; color: var(--text-main);">
                                                        <%= candidate.candidateName %>
                                                    </div>
                                                    <% if (candidate.matchMeta?.recommendInvite) { %>
                                                        <div class="invite-suggest" style="margin-top: 4px;">✨
                                                            Recommended</div>
                                                        <% } %>
                                                </td>
                                                <td>
                                                    <div style="font-weight: 600;">
                                                        <%= candidate.yearsExperience %> Years
                                                    </div>
                                                </td>
                                                <td>
                                                    <div style="font-size: 0.8rem; color: var(--text-muted);">
                                                        <% if (candidate.assessmentStatus==='invited' ) { %>
                                                            <span class="badge badge-info"
                                                                style="font-size: 0.65rem;">INVITED</span>
                                                            <% } else if (candidate.assessmentStatus==='in_progress' ) {
                                                                %>
                                                                <span class="badge badge-warning"
                                                                    style="font-size: 0.65rem;">IN PROGRESS</span>
                                                                <% } else { %>
                                                                    <span class="badge badge-secondary"
                                                                        style="font-size: 0.65rem;">NEW</span>
                                                                    <% } %>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div style="font-weight: 800; font-size: 1rem;">
                                                        <%= candidate.matchMeta?.resumeScore || 0 %>%
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="action-btns">
                                                        <a href="/api/applications/application/<%= candidate._id %>/view"
                                                            class="btn btn-sm btn-secondary">Review</a>
                                                        <% if (candidate.assessmentStatus==='pending' &&
                                                            candidate.status !=='rejected' ) { %>
                                                            <button
                                                                onclick="openInviteModal('<%= candidate.candidate %>', '<%= candidate.candidateName %>', '<%= candidate._id %>')"
                                                                class="btn btn-sm">Invite</button>
                                                            <% } %>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>
        </div>

        <!-- Invite Modal -->
        <div id="message-modal" class="modal-overlay">
            <div class="modal-content">
                <div class="modal-header">
                    <h2>Invite Candidate</h2>
                    <button class="close-btn" onclick="closeInviteModal()">&times;</button>
                </div>
                <div class="modal-body">
                    <p>Sending invite to <strong id="modal-candidate-name"></strong> for <strong>
                            <%= job.title %>
                        </strong>.</p>

                    <div class="form-group mt-20">
                        <label>Message Preview</label>
                        <div id="message-preview"
                            style="background: #f8fafc; border: 1px solid var(--border); padding: 15px; border-radius: 8px; font-size: 0.85rem; color: var(--text-muted); line-height: 1.5;">
                            Loading template...
                        </div>
                    </div>

                    <div class="modal-actions mt-20">
                        <button class="btn btn-secondary" onclick="closeInviteModal()">Cancel</button>
                        <button class="btn" id="send-btn" onclick="sendMessage()">Send Invite</button>
                    </div>
                </div>
            </div>
        </div>

        <script>
            function showTab(tabId) {
                // Update buttons
                document.querySelectorAll('.tab-btn').forEach(btn => {
                    btn.classList.remove('active');
                    if (btn.getAttribute('onclick').includes(tabId)) btn.classList.add('active');
                });

                // Update content
                document.querySelectorAll('.tab-content').forEach(content => {
                    content.classList.remove('active');
                });
                document.getElementById(tabId).classList.add('active');
            }

            function filterCandidates(status) {
                const rows = document.querySelectorAll('.candidate-row');
                let count = 0;

                rows.forEach(row => {
                    const rowStatus = row.getAttribute('data-status');
                    let show = false;

                    if (status === 'all') show = true;
                    else if (status === 'waiting' && (rowStatus === 'applied' || rowStatus === 'invited_for_assessment')) show = true;
                    else if (status === 'shortlisted' && rowStatus === 'shortlisted') show = true;
                    else if (status === 'interview' && rowStatus === 'interview_scheduled') show = true;
                    else if (status === 'hired' && rowStatus === 'hired') show = true;
                    else if (status === 'rejected' && rowStatus === 'rejected') show = true;

                    if (show) {
                        row.style.display = '';
                        count++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                document.getElementById('filter-count').textContent = `Showing ${count} candidates`;
            }

            const jobId = "<%= job._id %>";
            const jobTitle = "<%= job.title %>";
            let currentCandidateId = null, currentCandidateName = null, currentAppId = null, templates = [];

            (async () => {
                try {
                    const res = await fetch(`/api/jobs/${jobId}/pool-insights`);
                    const data = await res.json();
                    if (data.success && data.data.poolStats.totalCandidates > 0) {
                        const s = data.data.poolStats;
                        document.getElementById('pi-avg-score-val').textContent = `${s.avgWeightedScore}%`;
                        document.getElementById('pi-high-pot-val').textContent = `${s.highPotentialCount} / ${s.totalCandidates}`;
                        document.getElementById('pi-avg-exp-val').textContent = `${s.avgExperience} yrs`;

                        ['pi-avg-card', 'pi-pot-card', 'pi-exp-card'].forEach(id => {
                            document.getElementById(id).style.display = 'block';
                        });
                    }
                } catch (e) { console.warn('Insights fail'); }
            })();

            async function openInviteModal(id, name, appId) {
                currentCandidateId = id; currentCandidateName = name; currentAppId = appId;
                document.getElementById('modal-candidate-name').textContent = name;
                document.getElementById('message-modal').classList.add('active');

                if (!templates.length) {
                    const res = await fetch('/api/notifications/templates');
                    const d = await res.json();
                    if (d.success) templates = d.data;
                }

                const t = templates.find(temp => temp.name === 'assessment_invite');
                if (t) {
                    document.getElementById('message-preview').textContent = t.body
                        .replace(/{{candidateName}}/g, name)
                        .replace(/{{jobTitle}}/g, jobTitle);
                }
            }

            function closeInviteModal() { document.getElementById('message-modal').classList.remove('active'); }

            async function sendMessage() {
                const btn = document.getElementById('send-btn');
                btn.disabled = true; btn.textContent = 'Sending...';
                try {
                    const res = await fetch('/api/notifications/send', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            recipientId: currentCandidateId,
                            templateName: 'assessment_invite',
                            data: { candidateName: currentCandidateName, jobTitle: jobTitle },
                            actionUrl: `/api/assessment/assessment/${currentAppId}`
                        })
                    });
                    if ((await res.json()).success) { alert('Invite Sent!'); closeInviteModal(); }
                } catch (e) { alert('Failed'); }
                finally { btn.disabled = false; btn.textContent = 'Send Invite'; }
            }
        </script>
</body>

</html>