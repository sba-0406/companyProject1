<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | ScenarioSim
    </title>
    <link rel="stylesheet" href="/css/style.css?v=9">
</head>

<body class="has-sidebar">
    <%- include('partials/_navbar') %>

        <div class="main-wrapper">
            <div class="container">
                <div class="dashboard-header mb-20">
                    <div class="grid-adaptive"
                        style="grid-template-columns: 1fr auto; align-items: center; width: 100%;">
                        <div>
                            <h1>HR Dashboard</h1>
                            <p style="color: var(--text-muted);">Welcome back, <%= user.name %>
                            </p>
                        </div>
                        <a href="/api/jobs/create/view" class="btn">+ Create Job</a>
                    </div>
                </div>

                <!-- Stats Overview -->
                <div class="grid-adaptive mb-20" style="grid-template-columns: repeat(4, 1fr);">
                    <div class="stat-card">
                        <h3>Total Jobs</h3>
                        <div class="stat-value" id="total-jobs">-</div>
                    </div>
                    <div class="stat-card">
                        <h3>Active Jobs</h3>
                        <div class="stat-value" id="active-jobs">-</div>
                    </div>
                    <div class="stat-card">
                        <h3>Total Applications</h3>
                        <div class="stat-value" id="total-applications">-</div>
                    </div>
                    <div class="stat-card">
                        <h3>Pending Reviews</h3>
                        <div class="stat-value" id="pending-reviews">-</div>
                    </div>
                </div>

                <!-- Recent Alerts Hub -->
                <div class="card mb-20" style="background: #fff; border-color: var(--primary-color);">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                        <h2 style="font-size: 1.1rem; display: flex; align-items: center; gap: 10px;">
                            <span>🔔</span> Recent Alerts
                        </h2>
                        <span id="unread-count-label" class="badge badge-danger" style="display: none;">0 New</span>
                    </div>
                    <div id="hr-alerts-list" class="grid-adaptive"
                        style="grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 12px;">
                        <div class="empty-state" style="padding: 20px;">Loading alerts...</div>
                    </div>
                </div>

                <!-- Jobs List -->
                <div class="card">
                    <div class="section-header mb-20"
                        style="display: flex; justify-content: space-between; align-items: center;">
                        <h2>Job Postings</h2>
                        <div class="filter-tabs" style="display: flex; gap: 10px;">
                            <button class="btn btn-secondary active" data-status="all">All</button>
                            <button class="btn btn-secondary" data-status="active">Active</button>
                        </div>
                    </div>

                    <div class="job-list grid-adaptive" id="job-list">
                        <div class="empty-state">
                            <p>Loading jobs...</p>
                        </div>
                    </div>

                    <!-- Pagination -->
                    <div id="pagination-container" class="pagination-wrapper mt-40"
                        style="display: flex; justify-content: center; gap: 10px; align-items: center;">
                        <!-- Buttons will be injected here -->
                    </div>
                </div>
            </div>
        </div>

        <script>
            let currentPage = 1;
            const limit = 6;
            let totalPages = 1;
            let currentFilter = 'all';

            // Fetch jobs on load
            async function loadJobs(page = 1) {
                try {
                    currentPage = page;
                    const params = new URLSearchParams({
                        page,
                        limit,
                        status: currentFilter === 'all' ? '' : currentFilter
                    });

                    const response = await fetch(`/api/jobs?${params.toString()}`);
                    const data = await response.json();

                    if (data.success) {
                        totalPages = data.totalPages;
                        // Special: We need all jobs for the stats overview, or a separate stats endpoint
                        // Since stats are global, we might need to fetch them once elsewhere
                        // For now, let's just update the list results
                        renderJobs(data.data, data.totalJobs);
                        renderPagination();

                        document.getElementById('total-jobs').textContent = data.totalJobs;
                        document.getElementById('active-jobs').textContent = data.overview.activeCount;
                        document.getElementById('total-applications').textContent = data.overview.totalApplications;
                        document.getElementById('pending-reviews').textContent = data.overview.totalAssessmentsCompleted;
                    }
                } catch (error) {
                    console.error('Error loading jobs:', error);
                    document.getElementById('job-list').innerHTML = `
                    <div class="empty-state">
                        <p>Error loading jobs. Please refresh the page.</p>
                    </div>
                `;
                }
            }

            // Fetch and render HR alerts
            async function loadHRAlerts() {
                try {
                    const res = await fetch('/api/notifications');
                    const data = await res.json();
                    if (data.success) {
                        renderHRAlerts(data.data.slice(0, 3), data.unreadCount);
                    }
                } catch (err) {
                    console.error('Failed to load HR alerts:', err);
                }
            }

            function renderHRAlerts(notifications, unreadCount) {
                const list = document.getElementById('hr-alerts-list');
                const badge = document.getElementById('unread-count-label');

                if (unreadCount > 0) {
                    badge.textContent = `${unreadCount} New`;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }

                if (!notifications || notifications.length === 0) {
                    list.innerHTML = '<div class="empty-state" style="grid-column: 1/-1; padding: 20px; color: var(--text-muted); font-size: 0.85rem;">No recent alerts.</div>';
                    return;
                }

                list.innerHTML = notifications.map(n => `
                    <div class="notification-item ${n.isRead ? '' : 'unread'}" 
                         style="border: 1px solid var(--border); border-radius: 10px; padding: 12px 15px; cursor: pointer; transition: all 0.2s;"
                         onclick="handleNotiClick(event, '${n._id}', '${n.actionUrl || ''}')">
                        <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                            <div class="noti-title" style="font-size: 0.85rem; font-weight: 700; color: var(--text-main);">${n.title}</div>
                            <div class="noti-time" style="font-size: 0.7rem; color: var(--text-muted);">${new Date(n.createdAt).toLocaleDateString()}</div>
                        </div>
                        <div class="noti-message" style="font-size: 0.8rem; color: var(--text-muted); line-height: 1.4;">${n.message}</div>
                    </div>
                `).join('');
            }

            function renderJobs(jobs, totalCount) {
                const jobList = document.getElementById('job-list');

                if (jobs.length === 0) {
                    jobList.innerHTML = `
                    <div class="empty-state">
                        <p>No jobs found. Create your first job posting!</p>
                    </div>
                `;
                    return;
                }

                jobList.innerHTML = jobs.map(job => `
                <div class="job-card">
                    <div class="job-card-header">
                        <span class="job-status status-${job.status}">${job.status.toUpperCase()}</span>
                    </div>
                    <div class="job-card-body">
                        <h3 class="job-title">${job.title}</h3>
                        <p class="job-meta-loc">📍 ${job.location} &nbsp;·&nbsp; 💼 ${job.department}</p>
                        <p class="job-meta-exp">⏱ ${job.experienceMin}–${job.experienceMax} yrs experience</p>
                    </div>
                    <div class="job-stats">
                        <div class="job-stat">
                            <span class="job-stat-value">${job.views || 0}</span>
                            <span class="job-stat-label">Views</span>
                        </div>
                        <div class="job-stat">
                            <span class="job-stat-value">${job.applications || 0}</span>
                            <span class="job-stat-label">Applied</span>
                        </div>
                        <div class="job-stat">
                            <span class="job-stat-value">${job.assessmentsCompleted || 0}</span>
                            <span class="job-stat-label">Completed</span>
                        </div>
                    </div>
                    <div class="job-actions">
                        <a href="/api/jobs/${job._id}/view" class="btn btn-sm">Details</a>
                        <a href="/api/jobs/${job._id}/candidates" class="btn btn-sm">Candidates</a>
                        <a href="/api/jobs/${job._id}/analytics" class="btn btn-sm btn-outline">Analytics</a>
                    </div>
                </div>
            `).join('');
            }

            function renderPagination() {
                const container = document.getElementById('pagination-container');
                if (totalPages <= 1) {
                    container.innerHTML = '';
                    return;
                }

                let html = `
                    <button class="pagination-btn" ${currentPage === 1 ? 'disabled' : ''} onclick="changePage(${currentPage - 1})">
                        <span>←</span> Prev
                    </button>
                    <div class="pagination-info">Page ${currentPage} of ${totalPages}</div>
                    <button class="pagination-btn" ${currentPage === totalPages ? 'disabled' : ''} onclick="changePage(${currentPage + 1})">
                        Next <span>→</span>
                    </button>
                `;
                container.innerHTML = html;
            }

            function changePage(page) {
                if (page < 1 || page > totalPages) return;
                loadJobs(page);
                window.scrollTo({ top: 300, behavior: 'smooth' }); // Scroll to table
            }

            // Filter tabs
            document.querySelectorAll('.filter-tabs button').forEach(btn => {
                btn.addEventListener('click', () => {
                    document.querySelectorAll('.filter-tabs button').forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilter = btn.dataset.status;
                    loadJobs(1); // Reset to first page
                });
            });

            // Load data on page load
            loadJobs();
            loadHRAlerts();

            // Refresh alerts periodically
            setInterval(loadHRAlerts, 60000);
        </script>
</body>

</html>